{
    "name": "astro-i18n-starter",
    "private": true,
    "version": "1.2.0",
    "type": "module",
    "description": "Multilingual Astro starter with URL localization and i18n support",
    "author": {
        "name": "Nik Klemenc",
        "url": "https://klemenc.si"
    },
    "homepage": "https://klemenc.si",
    "repository": {
        "type": "git",
        "url": "https://github.com/Scorpio3310/astro-i18n-starter"
    },
    "license": "MIT",
    "keywords": [
        "astro",
        "i18n",
        "internationalization",
        "multilingual",
        "url-localization",
        "seo",
        "tailwindcss",
        "static-site-generator"
    ],
    "scripts": {
        "dev": "astro dev",
        "build": "astro build",
        "db:generate": "drizzle-kit generate",
        "db:push": "drizzle-kit push",
        "start": "astro preview",
        "preview": "astro preview",
        "deploy": "astro build && wrangler deploy",
        "deploy:dry-run": "astro build && wrangler deploy --dry-run --outdir ./runtime/wrangler-dry-run",
        "cf:secrets": "node ./scripts/sync-wrangler-secrets.mjs",
        "cf:secrets:dry-run": "node ./scripts/sync-wrangler-secrets.mjs --dry-run",
        "test:smoke": "node ./scripts/smoke-test.mjs",
        "astro": "astro"
    },
    "dependencies": {
        "@astrojs/cloudflare": "^13.5.2",
        "@astrojs/mdx": "^5.0.3",
        "@astrojs/sitemap": "^3.7.2",
        "@astrojs/svelte": "^8.0.4",
        "@tailwindcss/vite": "^4.2.2",
        "astro": "^6.3.3",
        "drizzle-orm": "^0.45.2",
        "jose": "^6.2.3",
        "postgres": "^3.4.9",
        "sharp": "^0.34.5",
        "stripe": "^22.1.1",
        "svelte": "^5.55.1",
        "tailwindcss": "^4.2.2",
        "typescript": "^6.0.2"
    },
    "devDependencies": {
        "daisyui": "^5.5.20",
        "drizzle-kit": "^0.31.10",
        "wrangler": "^4.80.0"
    }
}
