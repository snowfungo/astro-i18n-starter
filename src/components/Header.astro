---
import navigationData from "@/data/navigationData";
import { getLangFromUrl, useTranslatedPath, useTranslations } from "@/i18n/utils";
import LanguagePicker from "@/components/LanguagePicker.astro";
import Button from "@/components/ui/Button.astro";
import Shell from "@/components/ui/Shell.astro";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);
const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";

const normalizePath = (value: string) => value.replace(/\/$/, "") || "/";
const isActive = (href: string) => {
    const translated = normalizePath(translatePath(href));
    return currentPath === translated || (translated !== "/" && currentPath.startsWith(`${translated}/`));
};

const linkClasses =
    "inline-flex items-center rounded-[14px] border border-transparent px-[0.92rem] py-[0.68rem] text-[0.95rem] font-semibold text-[var(--text-muted)] transition duration-200 ease-out";
const activeClasses = "border-[rgba(37,99,235,0.14)] bg-[rgba(37,99,235,0.08)] text-[var(--primary)]";
const toolNavigation = navigationData.filter((item) =>
    ["/photo-to-chibi", "/chibi-avatar-maker", "/chibi-couple-generator", "/features", "/blog", "/about"].includes(item.href),
);
---

<header class="sticky top-0 z-20 bg-[linear-gradient(180deg,rgba(248,250,252,0.96)_0%,rgba(248,250,252,0.82)_72%,rgba(248,250,252,0)_100%)] py-2 backdrop-blur-[14px]">
    <Shell>
        <div class="grid grid-cols-[minmax(0,220px)_minmax(0,1fr)_auto] items-center gap-[18px] rounded-[24px] border border-[rgba(148,163,184,0.18)] bg-[rgba(255,255,255,0.86)] px-5 py-3 shadow-[0_18px_40px_rgba(15,23,42,0.07)] max-[1080px]:grid-cols-[1fr_auto] max-[640px]:gap-[14px] max-[640px]:px-3.5 max-[640px]:py-3.5">
            <a class="grid grid-cols-[auto_minmax(0,1fr)] items-center gap-3.5 text-[var(--text-strong)] no-underline" href={translatePath("/") }>
                <span class="h-[2.2rem] w-[2.2rem] shrink-0 rounded-[14px] bg-[var(--brand-gradient)] shadow-[var(--brand-glow)]" aria-hidden="true"></span>
                <span class="block text-base font-bold tracking-[-0.03em]">{t("nav.brand")}</span>
            </a>

            <nav class="flex items-center justify-center gap-1 max-[1080px]:hidden" aria-label={t("nav.menu")}>
                <a href={translatePath("/")} class:list={[linkClasses, isActive("/") && activeClasses]}>{t("nav.home")}</a>

                <div class="header-dropdown relative">
                    <button class:list={[linkClasses, "header-dropdown__trigger"]} type="button" aria-expanded="false">
                        {t("nav.tools")}
                    </button>
                    <div class="header-dropdown__panel absolute left-1/2 top-[calc(100%+0.2rem)] z-20 grid min-w-[18rem] -translate-x-1/2 translate-y-2 gap-1.5 rounded-[20px] border border-[rgba(148,163,184,0.18)] bg-[rgba(255,255,255,0.98)] p-4 opacity-0 shadow-[0_22px_46px_rgba(15,23,42,0.12)] invisible">
                        <span class="absolute inset-x-0 -top-3 h-3"></span>
                        {
                            toolNavigation.map((item) => (
                                <a
                                    href={translatePath(item.href)}
                                    class:list={[
                                        "grid gap-1 rounded-[14px] border border-transparent bg-[#f8fbff] px-4 py-3 text-[var(--text-strong)] no-underline transition duration-200 ease-out hover:border-[rgba(37,99,235,0.18)] hover:bg-[rgba(37,99,235,0.08)] hover:text-[var(--primary)]",
                                        isActive(item.href) && "border-[rgba(37,99,235,0.18)] bg-[rgba(37,99,235,0.08)] text-[var(--primary)]",
                                    ]}
                                >
                                    <strong class="text-[0.94rem] font-semibold">{t(item.label)}</strong>
                                </a>
                            ))
                        }
                    </div>
                </div>

                <a href={translatePath("/pricing")} class:list={[linkClasses, isActive("/pricing") && activeClasses]}>{t("nav.pricing")}</a>
            </nav>

            <div class="flex items-center justify-end gap-3 max-[1080px]:hidden">
                <LanguagePicker label={t("footer.language")} class="min-w-36" />
                <Button href={translatePath("/dashboard")} variant="secondary" size="sm">{t("nav.dashboard")}</Button>
                <Button href="/api/auth/google" size="sm">{t("nav.login")}</Button>
            </div>

            <details class="relative hidden max-[1080px]:block">
                <summary class="flex min-h-[2.55rem] cursor-pointer list-none items-center rounded-xl border border-[var(--divider)] bg-white px-4 py-3 text-[0.94rem] font-semibold text-[var(--text-strong)]">
                    <span>{t("nav.menu")}</span>
                </summary>
                <div class="absolute right-0 top-[calc(100%+0.8rem)] grid w-[min(23rem,calc(100vw-24px))] gap-4 rounded-[20px] border border-[rgba(148,163,184,0.18)] bg-[rgba(255,255,255,0.98)] p-4 shadow-[0_22px_46px_rgba(15,23,42,0.12)] max-[640px]:left-0 max-[640px]:right-auto max-[640px]:w-full">
                    <div class="block"><strong>{t("nav.brand")}</strong></div>
                    <nav class="grid gap-2.5" aria-label={t("nav.menu")}>
                        <a href={translatePath("/")} class:list={["rounded-[14px] border border-transparent bg-[#f8fbff] px-4 py-3 text-[var(--text-muted)] no-underline", isActive("/") && "border-[rgba(37,99,235,0.18)] bg-[rgba(37,99,235,0.08)] text-[var(--primary)]"]}>{t("nav.home")}</a>
                        <span class="text-xs font-bold uppercase tracking-[0.08em] text-[var(--text-subtle)]">{t("nav.tools")}</span>
                        {
                            toolNavigation.map((item) => (
                                <a href={translatePath(item.href)} class:list={["rounded-[14px] border border-transparent bg-[#f8fbff] px-4 py-3 text-[var(--text-muted)] no-underline", isActive(item.href) && "border-[rgba(37,99,235,0.18)] bg-[rgba(37,99,235,0.08)] text-[var(--primary)]"]}>
                                    {t(item.label)}
                                </a>
                            ))
                        }
                        <a href={translatePath("/pricing")} class:list={["rounded-[14px] border border-transparent bg-[#f8fbff] px-4 py-3 text-[var(--text-muted)] no-underline", isActive("/pricing") && "border-[rgba(37,99,235,0.18)] bg-[rgba(37,99,235,0.08)] text-[var(--primary)]"]}>{t("nav.pricing")}</a>
                    </nav>
                    <div class="grid gap-2.5">
                        <LanguagePicker label={t("footer.language")} />
                        <Button href={translatePath("/dashboard")} variant="secondary">{t("nav.dashboard")}</Button>
                        <Button href="/api/auth/google">{t("nav.login")}</Button>
                    </div>
                </div>
            </details>
        </div>
    </Shell>
</header>

<script is:inline>
    (() => {
        const root = document.documentElement;
        root.classList.remove("nav-hover-ready");

        const enableHover = () => {
            root.classList.add("nav-hover-ready");
        };

        window.addEventListener("mousemove", enableHover, { once: true });
        window.addEventListener("touchstart", enableHover, { once: true });
    })();
</script>

<style>
    html.nav-hover-ready .header-dropdown:hover .header-dropdown__panel,
    .header-dropdown:focus-within .header-dropdown__panel,
    .header-dropdown__panel:hover {
        opacity: 1;
        visibility: visible;
        transform: translate(-50%, 0);
        pointer-events: auto;
    }

    html.nav-hover-ready .header-dropdown:hover .header-dropdown__trigger {
        border-color: rgba(37, 99, 235, 0.14);
        background: rgba(37, 99, 235, 0.08);
        color: var(--primary);
    }
</style>
