---
import navigationData from "@/data/navigationData";
import { getLangFromUrl, useTranslatedPath, useTranslations } from "@/i18n/utils";
import LanguagePicker from "@/components/LanguagePicker.astro";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);
const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";
---

<header class="site-header">
    <div class="shell header-row">
        <a class="brand" href={translatePath("/")}>{t("nav.brand")}</a>
        <nav class="nav-links">
            {
                navigationData.map((item) => {
                    const href = translatePath(item.href);
                    const active = currentPath === href.replace(/\/$/, "") || (href !== "/" && currentPath.startsWith(href));
                    return (
                        <a href={href} class:list={{ active }}>
                            {t(item.label)}
                        </a>
                    );
                })
            }
        </nav>
        <div class="header-actions">
            <LanguagePicker />
            <a class="ghost-button" href={translatePath("/dashboard")}>{t("nav.dashboard")}</a>
            <a class="primary-button" href="/api/auth/google">{t("nav.login")}</a>
        </div>
    </div>
</header>
