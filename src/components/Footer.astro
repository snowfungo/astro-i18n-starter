---
import navigationData from "@/data/navigationData";
import { getLangFromUrl, useTranslatedPath, useTranslations } from "@/i18n/utils";
import Shell from "@/components/ui/Shell.astro";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);
const year = new Date().getFullYear();
---

<footer class="site-footer">
    <Shell class="footer-grid">
        <div class="footer-copy">
            <strong>{t("nav.brand")}</strong>
            <p>{t("footer.tagline")}</p>
        </div>
        <nav class="footer-links">
            {
                navigationData.map((item) => (
                    <a href={translatePath(item.href)}>{t(item.label)}</a>
                ))
            }
            <a href={translatePath("/dashboard")}>{t("footer.dashboard")}</a>
        </nav>
    </Shell>
    <Shell class="footer-meta">
        <span>{t("footer.company")} © {year}</span>
        <span>{t("footer.rights")}</span>
    </Shell>
</footer>
