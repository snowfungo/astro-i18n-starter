---
import type { ChibiStyle } from "@/lib/server/config/app";
import { useTranslations } from "@/i18n/utils";
import Button from "@/components/ui/Button.astro";
import Card from "@/components/ui/Card.astro";
import Field from "@/components/ui/Field.astro";
import Input from "@/components/ui/Input.astro";
import Textarea from "@/components/ui/Textarea.astro";
import Badge from "@/components/ui/Badge.astro";

type LocalizedText = string | Record<string, string>;

type ExampleItem = {
    title: LocalizedText;
    image: string;
    alt: LocalizedText;
};

interface Props {
    lang?: string;
    formId: string;
    labels: {
        prompt: string;
        promptPlaceholder: string;
        photo: string;
        photoHelp: string;
        style: string;
        styleHelp: string;
        submit: string;
        generating: string;
        resultTitle: string;
        resultDesc: string;
        recentTitle?: string;
        recentEmpty?: string;
        download: string;
        tryAgain: string;
    };
    defaults?: {
        prompt?: string;
        style?: ChibiStyle;
    };
    examples?: ExampleItem[];
}

const { formId, labels, defaults, examples = [], lang = "en" } = Astro.props as Props;
const t = useTranslations(lang as never);
const styles: Array<{ value: ChibiStyle; label: string }> = [
    { value: "classic", label: String(t("style.classic")) },
    { value: "kawaii", label: String(t("style.kawaii")) },
    { value: "avatar", label: String(t("style.avatar")) },
    { value: "emoji", label: String(t("style.emoji")) },
];
const defaultStyle = defaults?.style ?? "classic";
const selectedStyleLabel = styles.find((style) => style.value === defaultStyle)?.label ?? styles[0].label;
const clientText = {
    submit: labels.submit,
    generating: labels.generating,
    generationFailed: String(t("common.generation_failed")),
    completedIn: String(t("common.completed_in")),
    resultAlt: String(t("common.generated_result_alt")),
    download: labels.download,
};
const panelClasses = "grid gap-6";
const layoutClasses = "grid gap-6 xl:grid-cols-[minmax(0,1.05fr)_minmax(320px,0.95fr)]";
const formClasses = "grid gap-5";
const fieldsClasses = "grid gap-5 md:grid-cols-2";
const selectTriggerClasses =
    "flex min-h-[3.25rem] w-full cursor-pointer list-none items-center justify-between rounded-[14px] border border-[var(--input-border)] bg-[var(--input-bg)] px-4 py-3 text-left text-[var(--text-strong)] shadow-[var(--input-shadow)] transition duration-150 ease-out hover:border-[var(--primary)] hover:shadow-[var(--focus-ring)]";
const selectMenuClasses =
    "absolute left-0 right-0 top-[calc(100%+0.7rem)] z-20 grid gap-1 rounded-[18px] border border-[rgba(148,163,184,0.2)] bg-[rgba(255,255,255,0.98)] p-2 shadow-[0_20px_44px_rgba(15,23,42,0.12)]";
const optionClasses =
    "flex min-h-[2.8rem] items-center rounded-xl px-3.5 py-3 text-left font-semibold text-[var(--text-strong)] transition duration-150 ease-out hover:bg-[rgba(37,99,235,0.08)] hover:text-[var(--primary)]";
const previewClasses =
    "flex min-h-[20rem] items-center justify-center overflow-hidden rounded-[24px] border border-dashed border-[rgba(37,99,235,0.22)] bg-[rgba(255,255,255,0.72)] p-5 text-sm font-semibold tracking-[0.04em] text-[var(--text-subtle)]";
const examplesClasses = "grid gap-4 sm:grid-cols-2 xl:grid-cols-4";
const exampleCardClasses =
    "overflow-hidden rounded-[20px] border border-[var(--card-border)] bg-[var(--surface-raised)] p-3 shadow-[0_14px_30px_rgba(15,23,42,0.06)] transition duration-200 ease-out hover:-translate-y-0.5 hover:border-[rgba(37,99,235,0.22)] hover:shadow-[var(--card-shadow-hover)]";
---

<div data-generator-panel class={panelClasses}>
    <section class={layoutClasses}>
        <Card class="p-6 md:p-7" tone="soft">
            <form id={formId} class={formClasses}>
                <Field label={labels.prompt}>
                    <Textarea name="prompt" rows="5" placeholder={labels.promptPlaceholder} value={defaults?.prompt ?? ""} />
                </Field>

                <div class={fieldsClasses}>
                    <Field label={labels.photo} hint={labels.photoHelp}>
                        <Input type="file" name="image" accept="image/*" />
                    </Field>

                    <Field label={labels.style} hint={labels.styleHelp}>
                        <details class="relative" data-style-select>
                            <summary class={selectTriggerClasses}>
                                <span data-style-current>{selectedStyleLabel}</span>
                                <span class="h-[0.55rem] w-[0.55rem] rotate-45 border-b-2 border-r-2 border-current opacity-65"></span>
                            </summary>
                            <div class={selectMenuClasses}>
                                {
                                    styles.map((style) => (
                                        <button
                                            type="button"
                                            class={optionClasses}
                                            data-style-option
                                            data-style-value={style.value}
                                            data-style-label={style.label}
                                            data-active={style.value === defaultStyle ? "true" : "false"}
                                        >
                                            {style.label}
                                        </button>
                                    ))
                                }
                            </div>
                        </details>
                        <input type="hidden" name="style" value={defaultStyle} data-style-input />
                    </Field>
                </div>

                <Button type="submit" data-submit-button class="w-full justify-center md:w-auto">
                    {labels.submit}
                </Button>
            </form>
        </Card>

        <Card class="grid gap-5 p-6 md:p-7" tone="highlight" data-result-card>
            <div class="grid gap-3">
                <Badge>{labels.resultTitle}</Badge>
                <div class="grid gap-2">
                    <h3 class="mb-0">{labels.resultDesc}</h3>
                    <p class="min-h-[1.5rem] text-sm text-[var(--text-muted)]" data-result-status></p>
                </div>
            </div>

            <div class={previewClasses} data-result-preview data-state="idle">
                <span>1024 × 1024</span>
            </div>

            <div class="flex flex-wrap items-center gap-3" data-result-actions hidden>
                <Button type="button" data-download-button>{labels.download}</Button>
                <Button type="button" variant="ghost" data-reset-button>{labels.tryAgain}</Button>
            </div>
        </Card>
    </section>

    {
        examples.length > 0 && (
            <div class={examplesClasses}>
                {
                    examples.map((example) => (
                        <figure class={exampleCardClasses}>
                            <img
                                src={example.image}
                                alt={typeof example.alt === "string" ? example.alt : example.alt[lang] ?? example.alt.en}
                                loading="lazy"
                                class="aspect-square w-full rounded-[16px] object-cover"
                            />
                            <figcaption class="mt-3 text-sm font-semibold text-[var(--text-strong)]">
                                {typeof example.title === "string" ? example.title : example.title[lang] ?? example.title.en}
                            </figcaption>
                        </figure>
                    ))
                }
            </div>
        )
    }
</div>

<script is:inline define:vars={{ clientText }}>
    (() => {
        const root = document.currentScript?.previousElementSibling;
        if (!root || root.dataset.generatorBound === "true") {
            return;
        }
        root.dataset.generatorBound = "true";
        const form = root.querySelector("form");
        const status = root.querySelector("[data-result-status]");
        const preview = root.querySelector("[data-result-preview]");
        const actions = root.querySelector("[data-result-actions]");
        const submitButton = root.querySelector("[data-submit-button]");
        const downloadButton = root.querySelector("[data-download-button]");
        const resetButton = root.querySelector("[data-reset-button]");
        const styleSelect = root.querySelector("[data-style-select]");
        const styleInput = root.querySelector("[data-style-input]");
        const styleCurrent = root.querySelector("[data-style-current]");
        const styleOptions = root.querySelectorAll("[data-style-option]");
        if (!(form instanceof HTMLFormElement) || !status || !preview || !actions || !(submitButton instanceof HTMLButtonElement) || !(downloadButton instanceof HTMLButtonElement)) {
            return;
        }

        if (styleSelect instanceof HTMLDetailsElement && styleInput instanceof HTMLInputElement && styleCurrent) {
            const syncStyle = (value, label) => {
                styleInput.value = value;
                styleCurrent.textContent = label;
                styleOptions.forEach((option) => {
                    option.dataset.active = option.getAttribute("data-style-value") === value ? "true" : "false";
                });
                styleSelect.open = false;
            };

            styleOptions.forEach((option) => {
                option.addEventListener("click", () => {
                    syncStyle(option.getAttribute("data-style-value") || "classic", option.getAttribute("data-style-label") || option.textContent || "");
                });
            });

            document.addEventListener("click", (event) => {
                if (!(event.target instanceof Node) || !styleSelect.contains(event.target)) {
                    styleSelect.open = false;
                }
            });

            document.addEventListener("keydown", (event) => {
                if (event.key === "Escape") {
                    styleSelect.open = false;
                }
            });
        }

        let latestOutputUrl = "";
        let latestFileName = "chibi-image.png";

        const setSubmitting = (submitting) => {
            root.dataset.submitting = submitting ? "true" : "false";
            submitButton.disabled = submitting;
            submitButton.dataset.loading = submitting ? "true" : "false";
            submitButton.setAttribute("aria-busy", submitting ? "true" : "false");
            submitButton.textContent = submitting ? clientText.generating : clientText.submit;
        };

        const reset = () => {
            preview.dataset.state = "idle";
            preview.innerHTML = "<span>1024 × 1024</span>";
            status.textContent = "";
            actions.hidden = true;
            latestOutputUrl = "";
            latestFileName = "chibi-image.png";
            setSubmitting(false);
        };

        const inferExtension = (url) => {
            if (url.startsWith("data:image/svg+xml")) return "svg";
            if (url.startsWith("data:image/png")) return "png";
            if (url.startsWith("data:image/jpeg")) return "jpg";
            const match = url.match(/\.([a-zA-Z0-9]+)(?:\?|$)/);
            return match?.[1] || "png";
        };

        const downloadCurrent = async () => {
            if (!latestOutputUrl) {
                return;
            }
            try {
                let href = latestOutputUrl;
                if (!latestOutputUrl.startsWith("data:")) {
                    const response = await fetch(latestOutputUrl);
                    if (!response.ok) {
                        throw new Error(clientText.generationFailed);
                    }
                    const blob = await response.blob();
                    href = URL.createObjectURL(blob);
                }
                const link = document.createElement("a");
                link.href = href;
                link.download = latestFileName;
                document.body.appendChild(link);
                link.click();
                link.remove();
                if (href.startsWith("blob:")) {
                    setTimeout(() => URL.revokeObjectURL(href), 1000);
                }
            } catch (error) {
                status.textContent = error instanceof Error ? error.message : clientText.generationFailed;
            }
        };

        resetButton?.addEventListener("click", reset);
        downloadButton.addEventListener("click", downloadCurrent);
        reset();

        form.addEventListener("submit", async (event) => {
            event.preventDefault();
            const payload = new FormData(form);
            status.textContent = clientText.generating;
            actions.hidden = true;
            preview.dataset.state = "loading";
            preview.innerHTML = `<div class="result-placeholder"><span></span><strong>${clientText.generating}</strong></div>`;
            setSubmitting(true);
            try {
                const response = await fetch("/api/images/generate", {
                    method: "POST",
                    body: payload,
                });
                const data = await response.json();
                if (!response.ok) {
                    throw new Error(data.error || clientText.generationFailed);
                }
                latestOutputUrl = data.output_url;
                latestFileName = `chibi-image.${inferExtension(data.output_url)}`;
                status.textContent = `${clientText.completedIn} ${data.latency_ms || 0} ms`;
                preview.dataset.state = "ready";
                preview.innerHTML = `<img src="${data.output_url}" alt="${clientText.resultAlt}" loading="eager" />`;
                actions.hidden = false;
                window.dispatchEvent(new CustomEvent("chibi-generated", { detail: data }));
            } catch (error) {
                preview.dataset.state = "idle";
                preview.innerHTML = "<span>1024 × 1024</span>";
                status.textContent = error instanceof Error ? error.message : clientText.generationFailed;
            } finally {
                setSubmitting(false);
            }
        });
    })();
</script>

<style>
    [data-generator-panel] summary::-webkit-details-marker {
        display: none;
    }

    [data-style-select][open] > summary {
        border-color: var(--primary);
        box-shadow: var(--focus-ring);
    }

    [data-style-option][data-active="true"] {
        background: rgba(37, 99, 235, 0.08);
        color: var(--primary);
    }

    [data-result-preview][data-state="loading"] {
        background: linear-gradient(180deg, rgba(255, 255, 255, 0.78) 0%, rgba(233, 242, 255, 0.92) 100%);
        border-style: solid;
    }

    [data-result-preview][data-state="ready"] {
        padding: 0;
        border-style: solid;
        border-color: rgba(37, 99, 235, 0.16);
        background: rgba(255, 255, 255, 0.9);
    }

    [data-result-preview][data-state="ready"] img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .result-placeholder {
        display: grid;
        justify-items: center;
        gap: 0.9rem;
        color: var(--text-strong);
    }

    .result-placeholder span {
        width: 2.25rem;
        height: 2.25rem;
        border-radius: 999px;
        border: 3px solid rgba(37, 99, 235, 0.16);
        border-top-color: var(--primary);
        animation: generator-panel-spin 0.8s linear infinite;
    }

    @keyframes generator-panel-spin {
        to {
            transform: rotate(360deg);
        }
    }
</style>
