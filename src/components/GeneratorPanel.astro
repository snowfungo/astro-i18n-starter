---
import type { ChibiStyle } from "@/lib/server/config/app";
import { useTranslations } from "@/i18n/utils";
import Button from "@/components/ui/Button.astro";
import Card from "@/components/ui/Card.astro";
import Field from "@/components/ui/Field.astro";
import Input from "@/components/ui/Input.astro";
import Select from "@/components/ui/Select.astro";
import Textarea from "@/components/ui/Textarea.astro";
import Badge from "@/components/ui/Badge.astro";

type LocalizedText = string | Record<string, string>;

type ExampleItem = {
    title: LocalizedText;
    image: string;
    alt: LocalizedText;
};

interface Props {
    lang?: string;
    formId: string;
    labels: {
        prompt: string;
        promptPlaceholder: string;
        photo: string;
        photoHelp: string;
        style: string;
        styleHelp: string;
        submit: string;
        generating: string;
        resultTitle: string;
        resultDesc: string;
        recentTitle?: string;
        recentEmpty?: string;
        download: string;
        tryAgain: string;
    };
    defaults?: {
        prompt?: string;
        style?: ChibiStyle;
    };
    examples?: ExampleItem[];
}

const { formId, labels, defaults, examples = [], lang = "en" } = Astro.props as Props;
const t = useTranslations(lang as never);
const styles: Array<{ value: ChibiStyle; label: string }> = [
    { value: "classic", label: String(t("style.classic")) },
    { value: "kawaii", label: String(t("style.kawaii")) },
    { value: "avatar", label: String(t("style.avatar")) },
    { value: "emoji", label: String(t("style.emoji")) },
];
const clientText = {
    submit: labels.submit,
    generating: labels.generating,
    generationFailed: String(t("common.generation_failed")),
    completedIn: String(t("common.completed_in")),
    resultAlt: String(t("common.generated_result_alt")),
    download: labels.download,
};
---

<div data-generator-panel>
    <section class="generator-shell">
        <Card class="generator-card" tone="soft">
            <form id={formId} class="generator-form">
                <Field label={labels.prompt}>
                    <Textarea name="prompt" rows="5" placeholder={labels.promptPlaceholder} value={defaults?.prompt ?? ""} />
                </Field>
                <div class="generator-grid">
                    <Field label={labels.photo} hint={labels.photoHelp}>
                        <Input type="file" name="image" accept="image/*" />
                    </Field>
                    <Field label={labels.style} hint={labels.styleHelp}>
                        <Select name="style">
                            {
                                styles.map((style) => (
                                    <option value={style.value} selected={style.value === (defaults?.style ?? "classic")}>
                                        {style.label}
                                    </option>
                                ))
                            }
                        </Select>
                    </Field>
                </div>
                <Button type="submit" data-submit-button>{labels.submit}</Button>
            </form>
        </Card>
        <Card class="result-card" tone="highlight" data-result-card>
            <Badge>{labels.resultTitle}</Badge>
            <h3>{labels.resultDesc}</h3>
            <p class="result-status" data-result-status></p>
            <div class="result-preview" data-result-preview>
                <span>1024 × 1024</span>
            </div>
            <div class="result-actions" data-result-actions hidden>
                <Button type="button" data-download-button>{labels.download}</Button>
                <Button type="button" variant="ghost" data-reset-button>{labels.tryAgain}</Button>
            </div>
        </Card>
    </section>
    {
        examples.length > 0 && (
            <div class="examples-grid">
                {
                    examples.map((example) => (
                        <figure class="example-card ui-card">
                            <img src={example.image} alt={typeof example.alt === "string" ? example.alt : example.alt[lang] ?? example.alt.en} loading="lazy" />
                            <figcaption>{typeof example.title === "string" ? example.title : example.title[lang] ?? example.title.en}</figcaption>
                        </figure>
                    ))
                }
            </div>
        )
    }
</div>

<script is:inline define:vars={{ clientText }}>
    (() => {
        const root = document.currentScript?.previousElementSibling;
        if (!root || root.dataset.generatorBound === "true") {
            return;
        }
        root.dataset.generatorBound = "true";
        const form = root.querySelector("form");
        const status = root.querySelector("[data-result-status]");
        const preview = root.querySelector("[data-result-preview]");
        const actions = root.querySelector("[data-result-actions]");
        const submitButton = root.querySelector("[data-submit-button]");
        const downloadButton = root.querySelector("[data-download-button]");
        const resetButton = root.querySelector("[data-reset-button]");
        if (!(form instanceof HTMLFormElement) || !status || !preview || !actions || !(submitButton instanceof HTMLButtonElement) || !(downloadButton instanceof HTMLButtonElement)) {
            return;
        }

        let latestOutputUrl = "";
        let latestFileName = "chibi-image.png";

        const setSubmitting = (submitting) => {
            submitButton.disabled = submitting;
            submitButton.textContent = submitting ? clientText.generating : clientText.submit;
        };

        const reset = () => {
            preview.innerHTML = "<span>1024 × 1024</span>";
            status.textContent = "";
            actions.hidden = true;
            latestOutputUrl = "";
            latestFileName = "chibi-image.png";
            setSubmitting(false);
        };

        const inferExtension = (url) => {
            if (url.startsWith("data:image/svg+xml")) return "svg";
            if (url.startsWith("data:image/png")) return "png";
            if (url.startsWith("data:image/jpeg")) return "jpg";
            const match = url.match(/\.([a-zA-Z0-9]+)(?:\?|$)/);
            return match?.[1] || "png";
        };

        const downloadCurrent = async () => {
            if (!latestOutputUrl) {
                return;
            }
            try {
                let href = latestOutputUrl;
                if (!latestOutputUrl.startsWith("data:")) {
                    const response = await fetch(latestOutputUrl);
                    if (!response.ok) {
                        throw new Error(clientText.generationFailed);
                    }
                    const blob = await response.blob();
                    href = URL.createObjectURL(blob);
                }
                const link = document.createElement("a");
                link.href = href;
                link.download = latestFileName;
                document.body.appendChild(link);
                link.click();
                link.remove();
                if (href.startsWith("blob:")) {
                    setTimeout(() => URL.revokeObjectURL(href), 1000);
                }
            } catch (error) {
                status.textContent = error instanceof Error ? error.message : clientText.generationFailed;
            }
        };

        resetButton?.addEventListener("click", reset);
        downloadButton.addEventListener("click", downloadCurrent);
        reset();

        form.addEventListener("submit", async (event) => {
            event.preventDefault();
            const payload = new FormData(form);
            status.textContent = clientText.generating;
            actions.hidden = true;
            setSubmitting(true);
            try {
                const response = await fetch("/api/images/generate", {
                    method: "POST",
                    body: payload,
                });
                const data = await response.json();
                if (!response.ok) {
                    throw new Error(data.error || clientText.generationFailed);
                }
                latestOutputUrl = data.output_url;
                latestFileName = `chibi-image.${inferExtension(data.output_url)}`;
                status.textContent = `${clientText.completedIn} ${data.latency_ms || 0} ms`;
                preview.innerHTML = `<img src="${data.output_url}" alt="${clientText.resultAlt}" loading="eager" />`;
                actions.hidden = false;
                window.dispatchEvent(new CustomEvent("chibi-generated", { detail: data }));
            } catch (error) {
                status.textContent = error instanceof Error ? error.message : clientText.generationFailed;
            } finally {
                setSubmitting(false);
            }
        });
    })();
</script>
