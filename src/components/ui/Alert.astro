---
const { tone = "default", title, class: className, ...rest } = Astro.props;

const toneClasses = {
    default: "border-[var(--card-border)] bg-[var(--surface-soft)] text-[var(--text-strong)]",
    destructive: "border-[rgba(220,38,38,0.18)] bg-[var(--surface-danger-soft)] text-[var(--text-strong)]",
};
---

<div
    class:list={[
        "ui-alert rounded-2xl border px-4 py-4",
        toneClasses[tone] ?? toneClasses.default,
        className,
    ]}
    {...rest}
>
    {title && <strong>{title}</strong>}
    <slot />
</div>
