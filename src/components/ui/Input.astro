---
const { class: className, ...rest } = Astro.props;
---

<input
    class:list={[
        "ui-input w-full rounded-xl border border-[var(--input-border)] bg-[var(--input-bg)] px-4 py-[0.95rem] text-[var(--text-strong)] shadow-[var(--input-shadow)] transition duration-150 ease-out focus:border-[var(--primary)] focus:outline-none focus:shadow-[var(--focus-ring)]",
        className,
    ]}
    {...rest}
/>
