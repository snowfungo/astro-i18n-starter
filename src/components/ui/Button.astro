---
const {
    href,
    variant = "primary",
    size = "md",
    type = "button",
    class: className,
    ...rest
} = Astro.props;

const variantClasses = {
    primary: "btn-primary",
    secondary: "btn-secondary",
    ghost: "btn-ghost",
    danger: "btn-error",
};

const sizeClasses = {
    sm: "btn-sm",
    md: null,
    lg: "btn-lg",
};

const classes = [
    "ui-button",
    "btn",
    variantClasses[variant] ?? variantClasses.primary,
    `ui-button--${variant}`,
    sizeClasses[size] ?? null,
    size !== "md" ? `ui-button--${size}` : null,
    className,
];
---

{
    href ? (
        <a href={href} class:list={classes} {...rest}>
            <slot />
        </a>
    ) : (
        <button type={type} class:list={classes} {...rest}>
            <slot />
        </button>
    )
}
