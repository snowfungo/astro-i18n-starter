---
import Base from "@/layouts/Base.astro";
import GeneratorPanel from "@/components/GeneratorPanel.astro";
import { exampleGroups } from "@/lib/site/content";
import { getStats } from "@/lib/server/generation/service";
import { ensureAppReady } from "@/lib/server/startup";
import { useTranslations } from "@/i18n/utils";
import Card from "@/components/ui/Card.astro";
import Shell from "@/components/ui/Shell.astro";
import SectionHeading from "@/components/ui/SectionHeading.astro";
import StatCard from "@/components/ui/StatCard.astro";
import Button from "@/components/ui/Button.astro";
import Badge from "@/components/ui/Badge.astro";

await ensureAppReady();
const lang = "en" as const;
const t = useTranslations(lang);
const stats = await getStats();
const faqItems = t("pages:index.faq_items") as Array<{ q: string; a: string }>;
const featureCards = [1, 2, 3, 4].map((item) => ({
    title: t(`pages:index.index_styles.item${item}_title`),
    body: t(`pages:index.index_styles.item${item}_body`),
}));
const tips = [1, 2, 3, 4].map((item) => ({
    title: t(`pages:index.index_tips.item${item}_title`),
    body: t(`pages:index.index_tips.item${item}_body`),
}));
const infoCards = [1, 2, 3].map((item) => ({
    title: t(`pages:index.index_info.item${item}_title`),
    body: t(`pages:index.index_info.item${item}_body`),
}));

const sectionBase = "py-10 md:py-12 lg:py-[84px]";
const softSection = `${sectionBase} bg-[var(--surface-band-soft)]`;
const neutralSection = `${sectionBase} bg-[var(--surface-band-neutral)]`;
const faqSection = `${sectionBase} bg-[linear-gradient(180deg,#f8fafc_0%,#eef4fb_100%)]`;
const gridThree = "grid gap-[18px] md:grid-cols-2 xl:grid-cols-3";
const gridFour = "grid gap-[18px] md:grid-cols-2 xl:grid-cols-4";
---

<Base
    title={String(t("pages:index.hero_title"))}
    meta={{
        description: String(t("pages:index.hero_subtitle")),
        canonical: Astro.url.href,
    }}
>
    <section class="relative bg-[var(--surface-band-hero)] pb-6 pt-16 md:pt-[74px]">
        <Shell>
            <div class="grid gap-6">
                <div class="grid justify-items-center gap-4 px-2 text-center">
                    <Badge>{t("pages:index.hero_badge")}</Badge>
                    <h1 class="mb-0 max-w-[10ch]">{t("pages:index.hero_title")}</h1>
                    <p class="max-w-[54rem] text-[1.06rem] text-[var(--text-muted)]">{t("pages:index.hero_subtitle")}</p>
                    <div class="flex flex-wrap justify-center gap-3">
                        <Button href="#home-generator" size="lg">{t("cta.title")}</Button>
                    </div>
                </div>

                <div class="grid gap-[18px] md:grid-cols-3">
                    <StatCard value={stats.total} meta={t("pages:index.recent_title")} class="bg-[linear-gradient(180deg,rgba(255,255,255,0.98)_0%,#f8fbff_100%)]" />
                    <StatCard value={stats.today} meta={t("metrics.generated_today")} class="bg-[linear-gradient(180deg,rgba(255,255,255,0.98)_0%,#f8fbff_100%)]" />
                    <StatCard value={Object.keys(stats.styles).length} meta={t("metrics.style_count")} class="bg-[linear-gradient(180deg,rgba(255,255,255,0.98)_0%,#f8fbff_100%)]" />
                </div>
            </div>
        </Shell>
    </section>

    <section class={`${sectionBase} bg-[var(--surface-band-generator)]`} id="home-generator">
        <Shell>
            <GeneratorPanel
                formId="home-generator-form"
                labels={{
                    prompt: String(t("pages:index.label_prompt")),
                    promptPlaceholder: String(t("pages:index.prompt_placeholder")),
                    photo: String(t("pages:index.label_photo")),
                    photoHelp: String(t("pages:index.photo_help")),
                    style: String(t("pages:index.label_style")),
                    styleHelp: String(t("pages:index.style_help")),
                    submit: String(t("cta.title")),
                    generating: String(t("common.generating")),
                    resultTitle: String(t("pages:index.result_title")),
                    resultDesc: String(t("pages:index.result_desc")),
                    download: String(t("common.download")),
                    tryAgain: String(t("common.try_again")),
                }}
                lang={lang}
                examples={exampleGroups.home}
            />
        </Shell>
    </section>

    <section class={softSection}>
        <Shell>
            <SectionHeading title={t("pages:index.index_info.title")} description={t("pages:index.index_info.description")} />
            <div class={`${gridThree} mt-6`}>
                {
                    infoCards.map((card) => (
                        <Card>
                            <h3>{card.title}</h3>
                            <p>{card.body}</p>
                        </Card>
                    ))
                }
            </div>
        </Shell>
    </section>

    <section class={neutralSection}>
        <Shell>
            <SectionHeading title={t("pages:index.index_styles.title")} description={t("pages:index.index_styles.description")} />
            <div class={`${gridFour} mt-6`}>
                {
                    featureCards.map((card) => (
                        <Card>
                            <h3>{card.title}</h3>
                            <p>{card.body}</p>
                        </Card>
                    ))
                }
            </div>
        </Shell>
    </section>

    <section class={softSection}>
        <Shell>
            <SectionHeading title={t("pages:index.index_tips.title")} description={t("pages:index.index_tips.description")} />
            <div class={`${gridFour} mt-6`}>
                {
                    tips.map((tip) => (
                        <Card>
                            <h3>{tip.title}</h3>
                            <p>{tip.body}</p>
                        </Card>
                    ))
                }
            </div>
        </Shell>
    </section>

    <section class={faqSection}>
        <Shell>
            <div class="grid gap-6">
                <SectionHeading title={t("pages:index.faq_title")} />
                <div class={gridThree}>
                    {
                        faqItems.map((item) => (
                            <Card class="bg-[linear-gradient(180deg,#ffffff_0%,#f8fafc_100%)]">
                                <h3>{item.q}</h3>
                                <p>{item.a}</p>
                            </Card>
                        ))
                    }
                </div>
            </div>
        </Shell>
    </section>
</Base>
