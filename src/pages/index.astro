---
import Base from "@/layouts/Base.astro";
import GeneratorPanel from "@/components/GeneratorPanel.astro";
import { exampleGroups } from "@/lib/site/content";
import { getStats } from "@/lib/server/generation/service";
import { ensureAppReady } from "@/lib/server/startup";
import { useTranslations, useTranslatedPath } from "@/i18n/utils";
import Card from "@/components/ui/Card.astro";
import Shell from "@/components/ui/Shell.astro";
import SectionHeading from "@/components/ui/SectionHeading.astro";
import StatCard from "@/components/ui/StatCard.astro";
import Button from "@/components/ui/Button.astro";
import Badge from "@/components/ui/Badge.astro";

await ensureAppReady();
const lang = "en" as const;
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);
const stats = await getStats();
const faqItems = t("pages:index.faq_items") as Array<{ q: string; a: string }>;
const featureCards = [1, 2, 3, 4].map((item) => ({
    title: t(`pages:index.index_styles.item${item}_title`),
    body: t(`pages:index.index_styles.item${item}_body`),
}));
const tips = [1, 2, 3, 4].map((item) => ({
    title: t(`pages:index.index_tips.item${item}_title`),
    body: t(`pages:index.index_tips.item${item}_body`),
}));
const infoCards = [1, 2, 3].map((item) => ({
    title: t(`pages:index.index_info.item${item}_title`),
    body: t(`pages:index.index_info.item${item}_body`),
}));
---

<Base
    title={String(t("pages:index.hero_title"))}
    meta={{
        description: String(t("pages:index.hero_subtitle")),
        canonical: Astro.url.href,
    }}
>
    <section class="hero">
        <Shell class="hero-grid">
            <div class="hero-copy">
                <Badge>{t("pages:index.hero_badge")}</Badge>
                <h1>{t("pages:index.hero_title")}</h1>
                <p>{t("pages:index.hero_subtitle")}</p>
                <div class="action-row">
                    <Button href="#home-generator">{t("cta.title")}</Button>
                    <Button href={translatePath("/pricing")} variant="ghost">{t("nav.pricing")}</Button>
                </div>
                <div class="stat-grid" style="margin-top:24px;">
                    <StatCard value={stats.total} meta={t("pages:index.recent_title")} />
                    <StatCard value={stats.today} meta={t("metrics.generated_today")} />
                    <StatCard value={Object.keys(stats.styles).length} meta={t("metrics.style_count")} />
                </div>
            </div>
            <Card class="hero-panel" tone="highlight">
                <SectionHeading title={t("pages:index.tools_title")} description={t("pages:index.tools_desc")} />
                <div class="card-grid">
                    <Card><h3>{t("nav.photo")}</h3><p>{t("pages:index.tool_photo_desc")}</p></Card>
                    <Card><h3>{t("nav.avatar")}</h3><p>{t("pages:index.tool_avatar_desc")}</p></Card>
                    <Card><h3>{t("nav.couple")}</h3><p>{t("pages:index.tool_couple_desc")}</p></Card>
                </div>
            </Card>
        </Shell>
    </section>

    <Shell id="home-generator">
        <GeneratorPanel
            formId="home-generator-form"
            labels={{
                prompt: String(t("pages:index.label_prompt")),
                promptPlaceholder: String(t("pages:index.prompt_placeholder")),
                photo: String(t("pages:index.label_photo")),
                photoHelp: String(t("pages:index.photo_help")),
                style: String(t("pages:index.label_style")),
                styleHelp: String(t("pages:index.style_help")),
                submit: String(t("cta.title")),
                generating: String(t("common.generating")),
                resultTitle: String(t("pages:index.result_title")),
                resultDesc: String(t("pages:index.result_desc")),
                download: String(t("common.download")),
                tryAgain: String(t("common.try_again")),
            }}
            lang={lang}
            examples={exampleGroups.home}
        />
    </Shell>

    <section class="section">
        <Shell class="card-grid">
            {
                infoCards.map((card) => (
                    <Card>
                        <h3>{card.title}</h3>
                        <p>{card.body}</p>
                    </Card>
                ))
            }
        </Shell>
    </section>

    <section class="section">
        <Shell>
            <SectionHeading title={t("pages:index.index_styles.title")} description={t("pages:index.index_styles.description")} />
            <div class="card-grid" style="margin-top:18px;">
                {
                    featureCards.map((card) => (
                        <Card>
                            <h3>{card.title}</h3>
                            <p>{card.body}</p>
                        </Card>
                    ))
                }
            </div>
        </Shell>
    </section>

    <section class="section">
        <Shell>
            <SectionHeading title={t("pages:index.index_tips.title")} description={t("pages:index.index_tips.description")} />
            <div class="card-grid" style="margin-top:18px;">
                {
                    tips.map((tip) => (
                        <Card>
                            <h3>{tip.title}</h3>
                            <p>{tip.body}</p>
                        </Card>
                    ))
                }
            </div>
        </Shell>
    </section>

    <section class="section">
        <Shell>
            <Card class="faq-card" tone="soft">
                <SectionHeading title={t("pages:index.faq_title")} />
                <div class="list-grid" style="margin-top:18px;">
                    {
                        faqItems.map((item) => (
                            <Card>
                                <h3>{item.q}</h3>
                                <p>{item.a}</p>
                            </Card>
                        ))
                    }
                </div>
            </Card>
        </Shell>
    </section>
</Base>
