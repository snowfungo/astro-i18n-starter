---
import Base from "@/layouts/Base.astro";
import GeneratorPanel from "@/components/GeneratorPanel.astro";
import { exampleGroups } from "@/lib/site/content";
import { getStats } from "@/lib/server/generation/service";
import { ensureAppReady } from "@/lib/server/startup";
import { useTranslations, useTranslatedPath } from "@/i18n/utils";

await ensureAppReady();
const lang = "en" as const;
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);
const stats = await getStats();
const faqItems = t("pages:index.faq_items") as Array<{ q: string; a: string }>;
const featureCards = [1, 2, 3, 4].map((item) => ({
    title: t(`pages:index.index_styles.item${item}_title`),
    body: t(`pages:index.index_styles.item${item}_body`),
}));
const tips = [1, 2, 3, 4].map((item) => ({
    title: t(`pages:index.index_tips.item${item}_title`),
    body: t(`pages:index.index_tips.item${item}_body`),
}));
const infoCards = [1, 2, 3].map((item) => ({
    title: t(`pages:index.index_info.item${item}_title`),
    body: t(`pages:index.index_info.item${item}_body`),
}));
---

<Base
    title={String(t("pages:index.hero_title"))}
    meta={{
        description: String(t("pages:index.hero_subtitle")),
        canonical: Astro.url.href,
    }}
>
    <section class="hero">
        <div class="shell hero-grid">
            <div class="hero-copy">
                <span class="eyebrow">{t("pages:index.hero_badge")}</span>
                <h1>{t("pages:index.hero_title")}</h1>
                <p>{t("pages:index.hero_subtitle")}</p>
                <div class="action-row">
                    <a class="primary-button" href="#home-generator">{t("common.download")}</a>
                    <a class="ghost-button" href={translatePath("/pricing")}>{t("nav.pricing")}</a>
                </div>
                <div class="stat-grid" style="margin-top:24px;">
                    <article class="stat-card">
                        <strong>{stats.total}</strong>
                        <p>{t("pages:index.recent_title")}</p>
                    </article>
                    <article class="stat-card">
                        <strong>{stats.today}</strong>
                        <p>{t("metrics.generated_today")}</p>
                    </article>
                    <article class="stat-card">
                        <strong>{Object.keys(stats.styles).length}</strong>
                        <p>{t("metrics.style_count")}</p>
                    </article>
                </div>
            </div>
            <div class="hero-panel">
                <h2>{t("pages:index.tools_title")}</h2>
                <p>{t("pages:index.tools_desc")}</p>
                <div class="card-grid">
                    <article class="card">
                        <h3>{t("nav.photo")}</h3>
                        <p>{t("pages:index.tool_photo_desc")}</p>
                    </article>
                    <article class="card">
                        <h3>{t("nav.avatar")}</h3>
                        <p>{t("pages:index.tool_avatar_desc")}</p>
                    </article>
                    <article class="card">
                        <h3>{t("nav.couple")}</h3>
                        <p>{t("pages:index.tool_couple_desc")}</p>
                    </article>
                </div>
            </div>
        </div>
    </section>

    <div class="shell" id="home-generator">
        <GeneratorPanel
            formId="home-generator-form"
            labels={{
                prompt: String(t("pages:index.label_prompt")),
                promptPlaceholder: String(t("pages:index.prompt_placeholder")),
                photo: String(t("pages:index.label_photo")),
                photoHelp: String(t("pages:index.photo_help")),
                style: String(t("pages:index.label_style")),
                styleHelp: String(t("pages:index.style_help")),
                submit: String(t("cta.title")),
                generating: String(t("common.generating")),
                resultTitle: String(t("pages:index.result_title")),
                resultDesc: String(t("pages:index.result_desc")),
                download: String(t("common.download")),
                tryAgain: String(t("common.try_again")),
            }}
            lang={lang}
            examples={exampleGroups.home}
        />
    </div>

    <section class="section">
        <div class="shell card-grid">
            {
                infoCards.map((card) => (
                    <article class="card">
                        <h3>{card.title}</h3>
                        <p>{card.body}</p>
                    </article>
                ))
            }
        </div>
    </section>

    <section class="section">
        <div class="shell">
            <h2>{t("pages:index.index_styles.title")}</h2>
            <p class="muted">{t("pages:index.index_styles.description")}</p>
            <div class="card-grid" style="margin-top:18px;">
                {
                    featureCards.map((card) => (
                        <article class="card">
                            <h3>{card.title}</h3>
                            <p>{card.body}</p>
                        </article>
                    ))
                }
            </div>
        </div>
    </section>

    <section class="section">
        <div class="shell">
            <h2>{t("pages:index.index_tips.title")}</h2>
            <p class="muted">{t("pages:index.index_tips.description")}</p>
            <div class="card-grid" style="margin-top:18px;">
                {
                    tips.map((tip) => (
                        <article class="card">
                            <h3>{tip.title}</h3>
                            <p>{tip.body}</p>
                        </article>
                    ))
                }
            </div>
        </div>
    </section>

    <section class="section">
        <div class="shell faq-card">
            <h2>{t("pages:index.faq_title")}</h2>
            <div class="list-grid" style="margin-top:18px;">
                {
                    faqItems.map((item) => (
                        <article class="card">
                            <h3>{item.q}</h3>
                            <p>{item.a}</p>
                        </article>
                    ))
                }
            </div>
        </div>
    </section>
</Base>
