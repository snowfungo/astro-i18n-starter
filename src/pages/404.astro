---
export const prerender = false;

import { useTranslatedPath, getLangFromUrl, useTranslations } from "@i18n/utils";
import Base from "@layouts/Base.astro";
import Button from "@/components/ui/Button.astro";
import Shell from "@/components/ui/Shell.astro";
import Badge from "@/components/ui/Badge.astro";
import EmptyState from "@/components/ui/EmptyState.astro";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);
---

<Base
    title={t("pageNotFound.head.title")}
    meta={{
        description: t("pageNotFound:head.description"),
    }}
>
    <section class="py-10 md:py-12 lg:py-[84px]">
        <Shell>
            <EmptyState title={t("pageNotFound.title")} description={t("pageNotFound:head.description")}>
                <div class="mt-6 flex justify-center">
                    <Badge>404</Badge>
                </div>
                <div class="mt-6 flex justify-center">
                    <Button href={translatePath("/")}>{t("pageNotFound.link")}</Button>
                </div>
            </EmptyState>
        </Shell>
    </section>
</Base>
