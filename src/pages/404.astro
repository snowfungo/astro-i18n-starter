---
export const prerender = false;

import { useTranslatedPath, getLangFromUrl, useTranslations } from "@i18n/utils";
import Base from "@layouts/Base.astro";
import Button from "@/components/ui/Button.astro";
import Card from "@/components/ui/Card.astro";
import Shell from "@/components/ui/Shell.astro";
import Badge from "@/components/ui/Badge.astro";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);
---

<Base
    title={t("pageNotFound.head.title")}
    meta={{
        description: t("pageNotFound:head.description"),
    }}
>
    <section class="section">
        <Shell>
            <Card class="empty-card" tone="soft">
                <Badge>404</Badge>
                <h1>{t("pageNotFound.title")}</h1>
                <p>{t("pageNotFound:head.description")}</p>
                <div class="mt-16 flex justify-center">
                    <Button href={translatePath("/")}>{t("pageNotFound.link")}</Button>
                </div>
            </Card>
        </Shell>
    </section>
</Base>
