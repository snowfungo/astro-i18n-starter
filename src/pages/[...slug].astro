            <script is:inline define:vars={{ uiText }}>
                (() => {
                    const historyGrid = document.querySelector("[data-history-grid]");
                    const planCard = document.querySelector("[data-plan-card]");
                    const creditsCard = document.querySelector("[data-credits-card]");
                    const loginCallout = document.querySelector("[data-login-callout]");
                    const refreshButton = document.querySelector("[data-dashboard-refresh]");
                    const setCard = (card, value, meta) => {
                        if (!card) return;
                        const title = card.querySelector("h3")?.outerHTML || "";
                        card.innerHTML = `${title}<strong class="block text-[clamp(2rem,3vw,2.6rem)] leading-none tracking-[-0.04em] text-[var(--text-strong)]">${value}</strong><p class="text-[var(--text-muted)]">${meta}</p>`;
                    };
                    const renderHistory = (items) => {
                        if (!historyGrid) return;
                        historyGrid.innerHTML = "";
                        if (!items.length) {
                            historyGrid.innerHTML = `<article class="rounded-[20px] border border-[var(--card-border)] bg-[var(--surface-soft)] p-7 text-center shadow-[var(--card-shadow)]"><h3>${uiText.dashboardEmpty}</h3></article>`;
                            return;
                        }
                        for (const item of items) {
                            const card = document.createElement("article");
                            card.className = "overflow-hidden rounded-[20px] border border-[var(--card-border)] bg-[var(--surface-raised)] p-3 shadow-[0_14px_30px_rgba(15,23,42,0.06)] transition duration-200 ease-out hover:-translate-y-0.5 hover:border-[rgba(37,99,235,0.22)] hover:shadow-[var(--card-shadow-hover)]";
                            card.innerHTML = `<img src="${item.output_url}" alt="${item.prompt || uiText.fallbackPrompt}" loading="lazy" class="aspect-square w-full rounded-[16px] object-cover" /><figcaption class="mt-3 text-sm font-semibold text-[var(--text-strong)]">${item.prompt || item.style || uiText.fallbackName}</figcaption>`;
                            historyGrid.appendChild(card);
                        }
                    };
                    const load = async () => {
                        try {
                            const authResponse = await fetch("/api/auth/me", { credentials: "include" });
                            const auth = await authResponse.json();
                            if (!authResponse.ok || !auth.authenticated) {
                                loginCallout?.removeAttribute("hidden");
                                renderHistory([]);
                                setCard(planCard, uiText.anonymousPlan, uiText.dashboardAnonymous);
                                setCard(creditsCard, "0", uiText.dashboardNoSession);
                                return;
                            }
                            loginCallout?.setAttribute("hidden", "hidden");
                            const plan = auth.subscription?.plan ? (uiText[`plan${auth.subscription.plan.charAt(0).toUpperCase()}${auth.subscription.plan.slice(1)}`] || auth.subscription.plan) : uiText.defaultPlan;
                            const status = auth.subscription?.status ? (uiText[`status${auth.subscription.status.charAt(0).toUpperCase()}${auth.subscription.status.slice(1)}`] || auth.subscription.status) : uiText.defaultStatus;
                            setCard(planCard, plan, status);
                            setCard(creditsCard, String(auth.credits?.available ?? 0), auth.credits?.expiring_at || uiText.dashboardNoExpiry);
                            const history = await fetch("/api/images/history", { credentials: "include" }).then((res) => res.json());
                            renderHistory(history.items || []);
                        } catch {
                            if (historyGrid) historyGrid.innerHTML = `<article class="rounded-[20px] border border-[var(--card-border)] bg-[var(--surface-soft)] p-7 text-center shadow-[var(--card-shadow)]"><p>${JSON.stringify(uiText.dashboardHistoryError).slice(1, -1)}</p></article>`;
                        }
                    };
                    refreshButton?.addEventListener("click", load);
                    window.addEventListener("chibi-generated", load);
                    load();
                })();
            </script>
        ) : page.routeKey === "admin" ? (
            <section class={sectionBase}>
                <Shell>
                    <SectionHeading badge={t("pages:admin.label")} title={t("pages:admin.title")} description={t("pages:admin.subtitle")} />
                    <Card class="mt-6 grid gap-5" tone="soft">
                        <div class="flex flex-wrap items-center justify-between gap-3">
                            <Button type="button" variant="ghost" data-admin-refresh>{t("pages:admin.refresh")}</Button>
                            <span class="text-[var(--text-muted)]" data-admin-status>{t("pages:admin.loading")}</span>
                        </div>
                        <div class="overflow-x-auto">
                            <table class="w-full border-collapse">
                                <thead>
                                    <tr>
                                        <th class="border-b border-[rgba(148,163,184,0.16)] bg-[rgba(255,255,255,0.68)] px-3.5 py-4 text-left text-[var(--text-strong)]">{t("pages:admin.col_user")}</th>
                                        <th class="border-b border-[rgba(148,163,184,0.16)] bg-[rgba(255,255,255,0.68)] px-3.5 py-4 text-left text-[var(--text-strong)]">{t("pages:admin.col_plan")}</th>
                                        <th class="border-b border-[rgba(148,163,184,0.16)] bg-[rgba(255,255,255,0.68)] px-3.5 py-4 text-left text-[var(--text-strong)]">{t("pages:admin.col_usage")}</th>
                                        <th class="border-b border-[rgba(148,163,184,0.16)] bg-[rgba(255,255,255,0.68)] px-3.5 py-4 text-left text-[var(--text-strong)]">{t("pages:admin.col_registered")}</th>
                                        <th class="border-b border-[rgba(148,163,184,0.16)] bg-[rgba(255,255,255,0.68)] px-3.5 py-4 text-left text-[var(--text-strong)]">{t("pages:admin.col_actions")}</th>
                                    </tr>
                                </thead>
                                <tbody data-admin-body></tbody>
                            </table>
                        </div>
                    </Card>
                </Shell>
            </section>
            <script is:inline define:vars={{ uiText }}>
                (() => {
                    const body = document.querySelector("[data-admin-body]");
                    const status = document.querySelector("[data-admin-status]");
                    const refresh = document.querySelector("[data-admin-refresh]");
                    const render = (items) => {
                        if (!body) return;
                        body.innerHTML = "";
                        if (!items.length) {
                            body.innerHTML = `<tr><td colspan="5" class="px-3.5 py-4 text-[var(--text-muted)]">${uiText.adminNoUsers}</td></tr>`;
                            return;
                        }
                        for (const item of items) {
                            const tr = document.createElement("tr");
                            tr.innerHTML = `<td class="border-b border-[rgba(148,163,184,0.16)] px-3.5 py-4 text-[var(--text-muted)]">${item.name || item.email || uiText.adminUnnamed}</td><td class="border-b border-[rgba(148,163,184,0.16)] px-3.5 py-4"><select class="w-full rounded-xl border border-[var(--input-border)] bg-[var(--input-bg)] px-3.5 py-3 text-[var(--text-strong)] shadow-[var(--input-shadow)]" data-plan-select><option value="free" ${item.plan === "free" ? "selected" : ""}>${uiText.adminPlanFree}</option><option value="starter" ${item.plan === "starter" ? "selected" : ""}>${uiText.adminPlanStarter}</option><option value="standard" ${item.plan === "standard" ? "selected" : ""}>${uiText.adminPlanStandard}</option><option value="value" ${item.plan === "value" ? "selected" : ""}>${uiText.adminPlanValue}</option></select></td><td class="border-b border-[rgba(148,163,184,0.16)] px-3.5 py-4 text-[var(--text-muted)]">${item.credits} ${uiText.adminCreditsLabel} / ${item.total_images} ${uiText.adminImageUnit}</td><td class="border-b border-[rgba(148,163,184,0.16)] px-3.5 py-4 text-[var(--text-muted)]">${item.created_at}</td><td class="border-b border-[rgba(148,163,184,0.16)] px-3.5 py-4"><div class="flex flex-wrap items-center gap-3"><input class="w-full max-w-[100px] rounded-xl border border-[var(--input-border)] bg-[var(--input-bg)] px-3.5 py-3 text-[var(--text-strong)] shadow-[var(--input-shadow)]" type="number" value="10" step="1" /><button class="inline-flex min-h-[2.9rem] items-center justify-center gap-2 rounded-xl bg-[var(--button-ghost-bg)] px-4 text-[0.94rem] font-semibold text-[var(--button-ghost-fg)] transition duration-200 ease-out hover:-translate-y-px" data-fill>${uiText.adminCreditsButton}</button><button class="inline-flex min-h-[2.9rem] items-center justify-center gap-2 rounded-xl bg-[var(--button-primary-bg)] px-4 text-[0.94rem] font-semibold text-[var(--button-primary-fg)] shadow-[var(--button-primary-shadow)] transition duration-200 ease-out hover:-translate-y-px" data-set-plan>${uiText.adminPlanButton}</button></div></td>`;
                            const amountInput = tr.querySelector("input");
                            const planSelect = tr.querySelector("select");
                            tr.querySelector("[data-fill]")?.addEventListener("click", async () => {
                                await fetch("/api/admin/fill-credits", { method: "POST", headers: { "Content-Type": "application/json" }, body: JSON.stringify({ userId: item.id, amount: Number(amountInput?.value || 0) }) });
                                load();
                            });
                            tr.querySelector("[data-set-plan]")?.addEventListener("click", async () => {
                                await fetch("/api/admin/set-plan", { method: "POST", headers: { "Content-Type": "application/json" }, body: JSON.stringify({ userId: item.id, plan: planSelect?.value || "free" }) });
                                load();
                            });
                            body.appendChild(tr);
                        }
                    };
                    const load = async () => {
                        if (status) status.textContent = uiText.adminRefreshing;
                        const authResponse = await fetch("/api/auth/me", { credentials: "include" });
                        const auth = await authResponse.json().catch(() => null);
                        if (!authResponse.ok || !auth?.authenticated || auth.user?.role !== "admin") {
                            if (status) status.textContent = uiText.adminAccessRequired;
                            render([]);
                            return;
                        }
                        const response = await fetch("/api/admin/users", { credentials: "include" });
                        if (!response.ok) {
                            if (status) status.textContent = response.status === 403 ? uiText.adminAccessRequired : uiText.adminLoadFailed;
                            render([]);
                            return;
                        }
                        const payload = await response.json();
                        render(payload.items || []);
                        if (status) status.textContent = `${payload.items?.length || 0} ${uiText.adminStatusUsers}`;
                    };
                    refresh?.addEventListener("click", load);
                    load();
                })();
            </script>
        ) : null
    }

    <script is:inline define:vars={{ uiText }}>
        (() => {
            const message = document.querySelector("[data-payment-message]");
            const setMessage = (value) => {
                if (!message) return;
                message.hidden = !value;
                message.textContent = value || "";
            };
            document.querySelectorAll("[data-checkout-plan]").forEach((button) => {
                button.addEventListener("click", async () => {
                    const plan = button.getAttribute("data-checkout-plan");
                    if (!plan) return;
                    setMessage(uiText.paymentLoadingCheckout);
                    const response = await fetch("/api/payments/create-checkout", { method: "POST", headers: { "Content-Type": "application/json" }, body: JSON.stringify({ plan }) });
                    const payload = await response.json();
                    if (!response.ok) {
                        setMessage(payload.error || uiText.paymentCheckoutFailed);
                        return;
                    }
                    window.location.href = payload.url;
                });
            });
            document.querySelectorAll("[data-open-portal]").forEach((button) => {
                button.addEventListener("click", async () => {
                    const response = await fetch("/api/payments/create-portal", { method: "POST" });
                    const payload = await response.json();
                    if (!response.ok) {
                        alert(payload.error || uiText.paymentPortalFailed);
                        return;
                    }
                    window.location.href = payload.url;
                });
            });
        })();
    </script>
</Base>
