---
import Base from "@/layouts/Base.astro";
import GeneratorPanel from "@/components/GeneratorPanel.astro";
import Button from "@/components/ui/Button.astro";
import Card from "@/components/ui/Card.astro";
import EmptyState from "@/components/ui/EmptyState.astro";
import SectionHeading from "@/components/ui/SectionHeading.astro";
import Shell from "@/components/ui/Shell.astro";
import StatCard from "@/components/ui/StatCard.astro";
import { routes } from "@/i18n/routes";
import { useTranslatedPath, useTranslations } from "@/i18n/utils";
import { exampleGroups, getBlogPost, getBlogPosts } from "@/lib/site/content";
import { pricingCards } from "@/lib/site/plans";
import { getPathForRoute, getRoutedPage } from "@/lib/site/router";
import { getStats } from "@/lib/server/generation/service";
import { ensureAppReady } from "@/lib/server/startup";

await ensureAppReady();

const page = getRoutedPage(Astro.url);
const lang = page.lang;
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);
const availableKeys = new Set(Object.keys(routes[lang]));
const isKnownRoute = availableKeys.has(page.routeKey);
const stats = await getStats();

const faqItems = (key: string) => (t(key) as Array<{ q: string; a: string }>) ?? [];
const pageTitleByRoute: Record<string, string> = {
    home: String(t("pages:index.hero_title")),
    "photo-to-chibi": String(t("pages:photo-to-chibi.title")),
    "chibi-avatar-maker": String(t("pages:chibi-avatar-maker.title")),
    "chibi-couple-generator": String(t("pages:chibi-couple-generator.title")),
    pricing: String(t("pages:pricing.title")),
    features: String(t("pages:features.title")),
    about: String(t("pages:about.title")),
    dashboard: String(t("pages:dashboard.title")),
    admin: String(t("pages:admin.title")),
    blog: String(t("pages:blog.title")),
};
const pageDescriptionByRoute: Record<string, string> = {
    home: String(t("pages:index.hero_subtitle")),
    "photo-to-chibi": String(t("pages:photo-to-chibi.hero_subtitle")),
    "chibi-avatar-maker": String(t("pages:chibi-avatar-maker.hero_subtitle")),
    "chibi-couple-generator": String(t("pages:chibi-couple-generator.hero_subtitle")),
    pricing: String(t("pages:pricing.subtitle")),
    features: String(t("pages:features.subtitle")),
    about: String(t("pages:about.para1")),
    dashboard: String(t("pages:dashboard.subtitle")),
    admin: String(t("pages:admin.subtitle")),
    blog: String(t("pages:blog.subtitle")),
};

let render404 = page.isApi ? false : !isKnownRoute;
let blogPost = null;
if (!render404 && page.isBlogDetail) {
    blogPost = getBlogPost(lang, page.rest[0] ?? "");
    if (!blogPost) {
        render404 = true;
    }
}
if (render404) {
    Astro.response.status = 404;
}

const styleCards = [1, 2, 3, 4].map((item) => ({
    title: t(`pages:index.index_styles.item${item}_title`),
    body: t(`pages:index.index_styles.item${item}_body`),
}));
const tipCards = [1, 2, 3, 4].map((item) => ({
    title: t(`pages:index.index_tips.item${item}_title`),
    body: t(`pages:index.index_tips.item${item}_body`),
}));
const infoCards = [1, 2, 3].map((item) => ({
    title: t(`pages:index.index_info.item${item}_title`),
    body: t(`pages:index.index_info.item${item}_body`),
}));
const featureBlocks = [1, 2, 3, 4, 5, 6].map((item) => ({
    title: t(`pages:features.card${item}_title`),
    body: t(`pages:features.card${item}_desc`),
}));
const aboutValues = [1, 2, 3].map((item) => ({
    title: t(`pages:about.value${item}_title`),
    body: t(`pages:about.value${item}_desc`),
}));
const photoSteps = [1, 2, 3, 4].map((item) => ({
    title: t(`pages:photo-to-chibi.step${item}_title`),
    body: t(`pages:photo-to-chibi.step${item}_body`),
}));
const photoTips = [1, 2, 3, 4].map((item) => ({
    title: t(`pages:photo-to-chibi.tip${item}_title`),
    body: t(`pages:photo-to-chibi.tip${item}_body`),
}));
const avatarSteps = [1, 2, 3, 4].map((item) => ({
    title: t(`pages:chibi-avatar-maker.step${item}_title`),
    body: t(`pages:chibi-avatar-maker.step${item}_body`),
}));
const avatarIdeas = [1, 2, 3].map((item) => ({
    title: t(`pages:chibi-avatar-maker.avatar_ideas.item${item}_title`),
    body: t(`pages:chibi-avatar-maker.avatar_ideas.item${item}_body`),
}));
const avatarPerfectFor = [1, 2, 3].map((item) => ({
    title: t(`pages:chibi-avatar-maker.avatar_perfect_for.item${item}_title`),
    body: t(`pages:chibi-avatar-maker.avatar_perfect_for.item${item}_body`),
}));
const coupleSteps = [1, 2, 3, 4].map((item) => ({
    title: t(`pages:chibi-couple-generator.step${item}_title`),
    body: t(`pages:chibi-couple-generator.step${item}_body`),
}));
const coupleTips = [1, 2, 3].map((item) => ({
    title: t(`pages:chibi-couple-generator.tip${item}_title`),
    body: t(`pages:chibi-couple-generator.tip${item}_body`),
}));
const posts = getBlogPosts(lang);
const uiText = {
    ctaGenerate: String(t("cta.title")),
    statTotalGenerated: String(t("metrics.total_generated")),
    statTodayGenerated: String(t("metrics.generated_today")),
    statStyles: String(t("metrics.style_count")),
    readMinutesUnit: String(t("common.read_minutes_unit")),
    userUnit: String(t("common.user_unit")),
    imageUnit: String(t("common.image_unit")),
    fallbackName: String(t("dashboard.fallback_name")),
    fallbackPrompt: String(t("dashboard.fallback_name")),
    anonymousPlan: String(t("plan.free")),
    defaultPlan: String(t("plan.free")),
    defaultStatus: String(t("payment.status.active")),
    planFree: String(t("plan.free")),
    planStarter: String(t("plan.starter")),
    planStandard: String(t("plan.standard")),
    planValue: String(t("plan.value")),
    statusActive: String(t("payment.status.active")),
    statusCancelling: String(t("payment.status.cancelling")),
    dashboardAnonymous: String(t("dashboard.status_anonymous")),
    dashboardNoSession: String(t("dashboard.no_session")),
    dashboardNoExpiry: String(t("dashboard.no_expiry")),
    dashboardHistoryError: String(t("dashboard.load_error")),
    adminAccessRequired: String(t("admin.access_required")),
    adminStatusUsers: String(t("common.user_unit")),
    adminCreditsLabel: String(t("pages:admin.credits_btn")),
    adminImageUnit: String(t("common.image_unit")),
    adminPlanFree: String(t("plan.free")),
    adminPlanStarter: String(t("plan.starter")),
    adminPlanStandard: String(t("plan.standard")),
    adminPlanValue: String(t("plan.value")),
    adminUnnamed: String(t("pages:admin.unnamed")),
    paymentLoadingCheckout: String(t("payment.loading_checkout")),
    paymentCheckoutFailed: String(t("payment.checkout_failed")),
    paymentPortalFailed: String(t("payment.portal_failed")),
};
const metaTitle = render404
    ? String(t("error_404_title"))
    : page.isBlogDetail && blogPost
      ? blogPost.title
      : pageTitleByRoute[page.routeKey] ?? "AI Chibi Generator";
const metaDescription = render404
    ? String(t("error_404_desc"))
    : page.isBlogDetail && blogPost
      ? blogPost.excerpt
      : pageDescriptionByRoute[page.routeKey] ?? "AI Chibi Generator";
---

<Base title={metaTitle} meta={{ description: metaDescription, canonical: Astro.url.href, robots: render404 ? "noindex,nofollow" : "index,follow" }}>
    {
        render404 ? (
            <section class="section">
                <Shell>
                    <EmptyState title={String(t("error_404_title"))} description={String(t("error_404_desc"))}>
                        <div class="action-row">
                            <Button href={getPathForRoute(lang, "home")}>{String(t("error_back_home"))}</Button>
                        </div>
                    </EmptyState>
                </Shell>
            </section>
        ) : page.routeKey === "home" ? (
            <>
                <section class="hero">
                    <Shell class="hero-grid">
                        <div class="hero-copy">
                            <span class="eyebrow">{t("pages:index.hero_badge")}</span>
                            <h1>{t("pages:index.hero_title")}</h1>
                            <p>{t("pages:index.hero_subtitle")}</p>
                            <div class="action-row">
                                <Button href="#route-generator">{uiText.ctaGenerate}</Button>
                                <Button href={translatePath("/pricing")} variant="ghost">{t("nav.pricing")}</Button>
                            </div>
                        </div>
                        <Card class="hero-panel" tone="highlight">
                            <SectionHeading title={t("pages:index.recent_title")} description={t("pages:index.recent_desc")} />
                            <div class="stat-grid" style="margin-top:18px;">
                                <StatCard value={stats.total} meta={uiText.statTotalGenerated} />
                                <StatCard value={stats.today} meta={uiText.statTodayGenerated} />
                                <StatCard value={Object.keys(stats.styles).length} meta={uiText.statStyles} />
                            </div>
                        </Card>
                    </Shell>
                </section>
                <Shell id="route-generator">
                    <GeneratorPanel formId={`generator-${lang}`} labels={{ prompt: String(t("pages:index.label_prompt")), promptPlaceholder: String(t("pages:index.prompt_placeholder")), photo: String(t("pages:index.label_photo")), photoHelp: String(t("pages:index.photo_help")), style: String(t("pages:index.label_style")), styleHelp: String(t("pages:index.style_help")), submit: String(t("cta.title")), generating: String(t("common.generating")), resultTitle: String(t("pages:index.result_title")), resultDesc: String(t("pages:index.result_desc")), download: String(t("common.download")), tryAgain: String(t("common.try_again")) }} lang={lang} examples={exampleGroups.home} />
                </Shell>
                <section class="section"><Shell class="card-grid">{infoCards.map((card) => <Card><h3>{card.title}</h3><p>{card.body}</p></Card>)}</Shell></section>
                <section class="section"><Shell><SectionHeading title={t("pages:index.index_styles.title")} description={t("pages:index.index_styles.description")} /><div class="card-grid" style="margin-top:18px;">{styleCards.map((card) => <Card><h3>{card.title}</h3><p>{card.body}</p></Card>)}</div></Shell></section>
                <section class="section"><Shell><SectionHeading title={t("pages:index.index_tips.title")} description={t("pages:index.index_tips.description")} /><div class="card-grid" style="margin-top:18px;">{tipCards.map((card) => <Card><h3>{card.title}</h3><p>{card.body}</p></Card>)}</div></Shell></section>
                <section class="section"><Shell><Card class="faq-card" tone="soft"><SectionHeading title={t("pages:index.faq_title")} /><div class="list-grid" style="margin-top:18px;">{faqItems("pages:index.faq_items").map((item) => <Card><h3>{item.q}</h3><p>{item.a}</p></Card>)}</div></Card></Shell></section>
            </>
        ) : page.routeKey === "photo-to-chibi" ? (
            <>
                <section class="hero"><Shell class="hero-grid"><div class="hero-copy"><span class="eyebrow">{t("pages:photo-to-chibi.hero_badge")}</span><h1>{t("pages:photo-to-chibi.title")}</h1><p>{t("pages:photo-to-chibi.hero_subtitle")}</p></div><Card class="hero-panel" tone="highlight"><SectionHeading title={t("pages:photo-to-chibi.how_it_works_title")} /><div class="list-grid">{photoSteps.map((step) => <Card><h3>{step.title}</h3><p>{step.body}</p></Card>)}</div></Card></Shell></section>
                <Shell><GeneratorPanel formId={`photo-generator-${lang}`} labels={{ prompt: String(t("pages:photo-to-chibi.label_notes")), promptPlaceholder: String(t("pages:photo-to-chibi.notes_placeholder")), photo: String(t("pages:photo-to-chibi.label_photo")), photoHelp: String(t("pages:photo-to-chibi.photo_help")), style: String(t("pages:index.label_style")), styleHelp: String(t("pages:photo-to-chibi.style_help")), submit: String(t("pages:photo-to-chibi.generate_btn")), generating: String(t("common.generating")), resultTitle: String(t("pages:photo-to-chibi.result_title")), resultDesc: String(t("pages:index.result_desc")), download: String(t("common.download")), tryAgain: String(t("common.try_again")) }} defaults={{ style: "avatar" }} lang={lang} examples={exampleGroups.photo} /></Shell>
                <section class="section"><Shell><SectionHeading title={t("pages:photo-to-chibi.tips_title")} /><div class="card-grid">{photoTips.map((tip) => <Card><h3>{tip.title}</h3><p>{tip.body}</p></Card>)}</div></Shell></section>
                <section class="section"><Shell><Card class="faq-card" tone="soft"><SectionHeading title={t("pages:photo-to-chibi.photo_faq_title")} /><div class="list-grid">{faqItems("pages:photo-to-chibi.photo_faq_items").map((item) => <Card><h3>{item.q}</h3><p>{item.a}</p></Card>)}</div></Card></Shell></section>
            </>
        ) : page.routeKey === "chibi-avatar-maker" ? (
            <>
                <section class="hero"><Shell class="hero-grid"><div class="hero-copy"><span class="eyebrow">{t("pages:chibi-avatar-maker.hero_badge")}</span><h1>{t("pages:chibi-avatar-maker.title")}</h1><p>{t("pages:chibi-avatar-maker.hero_subtitle")}</p></div><Card class="hero-panel" tone="highlight"><SectionHeading title={t("pages:chibi-avatar-maker.avatar_perfect_for.title")} /><div class="list-grid">{avatarPerfectFor.map((item) => <Card><h3>{item.title}</h3><p>{item.body}</p></Card>)}</div></Card></Shell></section>
                <Shell><GeneratorPanel formId={`avatar-generator-${lang}`} labels={{ prompt: String(t("pages:chibi-avatar-maker.label_prompt")), promptPlaceholder: String(t("pages:chibi-avatar-maker.prompt_placeholder")), photo: String(t("pages:index.label_photo")), photoHelp: String(t("pages:chibi-avatar-maker.photo_help")), style: String(t("pages:index.label_style")), styleHelp: String(t("pages:chibi-avatar-maker.style_help")), submit: String(t("pages:chibi-avatar-maker.generate_btn")), generating: String(t("pages:chibi-avatar-maker.generating")), resultTitle: String(t("pages:chibi-avatar-maker.result_title")), resultDesc: String(t("pages:chibi-avatar-maker.result_desc")), download: String(t("common.download")), tryAgain: String(t("common.try_again")) }} defaults={{ prompt: String(t("pages:chibi-avatar-maker.prompt_default")), style: "kawaii" }} lang={lang} examples={exampleGroups.avatar} /></Shell>
                <section class="section"><Shell><SectionHeading title={t("pages:chibi-avatar-maker.how_title")} /><div class="card-grid">{avatarSteps.map((item) => <Card><h3>{item.title}</h3><p>{item.body}</p></Card>)}</div></Shell></section>
                <section class="section"><Shell><SectionHeading title={t("pages:chibi-avatar-maker.avatar_ideas.title")} description={t("pages:chibi-avatar-maker.avatar_ideas.description")} /><div class="card-grid">{avatarIdeas.map((item) => <Card><h3>{item.title}</h3><p>{item.body}</p></Card>)}</div></Shell></section>
                <section class="section"><Shell><Card class="faq-card" tone="soft"><SectionHeading title={t("pages:chibi-avatar-maker.avatar_faq_title")} /><div class="list-grid">{faqItems("pages:chibi-avatar-maker.avatar_faq_items").map((item) => <Card><h3>{item.q}</h3><p>{item.a}</p></Card>)}</div></Card></Shell></section>
            </>
        ) : page.routeKey === "chibi-couple-generator" ? (
            <>
                <section class="hero"><Shell class="hero-grid"><div class="hero-copy"><span class="eyebrow">{t("pages:chibi-couple-generator.hero_badge")}</span><h1>{t("pages:chibi-couple-generator.title")}</h1><p>{t("pages:chibi-couple-generator.hero_subtitle")}</p></div><Card class="hero-panel" tone="highlight"><SectionHeading title={t("pages:chibi-couple-generator.how_title")} /><div class="list-grid">{coupleSteps.map((item) => <Card><h3>{item.title}</h3><p>{item.body}</p></Card>)}</div></Card></Shell></section>
                <Shell><GeneratorPanel formId={`couple-generator-${lang}`} labels={{ prompt: String(t("pages:chibi-couple-generator.label_prompt")), promptPlaceholder: String(t("pages:chibi-couple-generator.prompt_placeholder")), photo: String(t("pages:chibi-couple-generator.label_photo")), photoHelp: String(t("pages:chibi-couple-generator.photo_help")), style: String(t("pages:index.label_style")), styleHelp: String(t("pages:chibi-couple-generator.style_help")), submit: String(t("pages:chibi-couple-generator.generate_btn")), generating: String(t("pages:chibi-couple-generator.generating")), resultTitle: String(t("pages:chibi-couple-generator.result_title")), resultDesc: String(t("pages:chibi-couple-generator.result_desc")), download: String(t("common.download")), tryAgain: String(t("common.try_again")) }} defaults={{ prompt: String(t("pages:chibi-couple-generator.prompt_default")), style: "kawaii" }} lang={lang} examples={exampleGroups.couple} /></Shell>
                <section class="section"><Shell><SectionHeading title={t("pages:chibi-couple-generator.tips_title")} /><div class="card-grid">{coupleTips.map((item) => <Card><h3>{item.title}</h3><p>{item.body}</p></Card>)}</div></Shell></section>
                <section class="section"><Shell><Card class="faq-card" tone="soft"><SectionHeading title={t("pages:chibi-couple-generator.couple_faq_title")} /><div class="list-grid">{faqItems("pages:chibi-couple-generator.couple_faq_items").map((item) => <Card><h3>{item.q}</h3><p>{item.a}</p></Card>)}</div></Card></Shell></section>
            </>
        ) : page.routeKey === "pricing" ? (
            <section class="section"><Shell><SectionHeading badge={t("pages:pricing.label")} title={t("pages:pricing.title")} description={t("pages:pricing.subtitle")} /><div class="pricing-grid" style="margin-top:24px;">{pricingCards.map((card) => <Card class="pricing-card" tone={card.featured ? "highlight" : "default"}><span class="eyebrow">{card.featured ? t("pages:pricing.popular") : t(`plan.${card.id}`)}</span><h3>{t(`pages:pricing.${card.id}_title`)}</h3><p>{t(`pages:pricing.${card.id}_desc`)}</p><strong class="metric">{card.priceLabel}</strong><p>{card.creditLabel ?? t(`pages:pricing.${card.id}_credit`)}</p>{card.featureKeys && <ul>{card.featureKeys.map((key) => <li>{t(key)}</li>)}</ul>}<div class="action-row" style="margin-top:16px;">{card.paid ? <Button type="button" data-checkout-plan={card.id}>{t(card.ctaKey)}</Button> : <Button href={getPathForRoute(lang, "home")} variant="ghost">{t(card.ctaKey)}</Button>}</div></Card>)}</div><div class="notice" data-payment-message hidden></div></Shell></section>
        ) : page.routeKey === "features" ? (
            <section class="section"><Shell><SectionHeading badge={t("pages:features.label")} title={t("pages:features.title")} description={t("pages:features.subtitle")} /><div class="card-grid" style="margin-top:24px;">{featureBlocks.map((block) => <Card><h3>{block.title}</h3><p>{block.body}</p></Card>)}</div><div class="page-actions" style="margin-top:24px;"><Button href={getPathForRoute(lang, "home")}>{t("pages:features.cta")}</Button></div></Shell></section>
        ) : page.routeKey === "about" ? (
            <section class="section"><Shell><SectionHeading badge={t("pages:about.label")} title={t("pages:about.title")} description={t("pages:about.para1")} /><Card class="list-card" tone="soft"><p>{t("pages:about.para2")}</p></Card><div class="card-grid" style="margin-top:24px;">{aboutValues.map((item) => <Card><h3>{item.title}</h3><p>{item.body}</p></Card>)}</div><div class="page-actions" style="margin-top:24px;"><Button href={getPathForRoute(lang, "home")}>{t("pages:about.cta")}</Button></div></Shell></section>
        ) : page.routeKey === "blog" && blogPost ? (
            <section class="section"><Shell><Card class="article-card" tone="soft"><span class="eyebrow">{t("pages:blog.title")}</span><h1>{blogPost.title}</h1><p class="article-intro">{blogPost.excerpt}</p><div class="meta-row"><span>{blogPost.publishedAt}</span><span>{blogPost.readMinutes} {uiText.readMinutesUnit}</span></div><img src={blogPost.cover} alt={blogPost.title} /><div class="list-grid">{blogPost.body.map((paragraph) => <Card><p>{paragraph}</p></Card>)}</div><div class="page-actions" style="margin-top:24px;"><Button href={getPathForRoute(lang, "blog")} variant="ghost">{t("pages:blog.back_to_list")}</Button></div></Card></Shell></section>
        ) : page.routeKey === "blog" ? (
            <section class="section"><Shell><SectionHeading badge={t("pages:blog.title")} title={t("pages:blog.title")} description={t("pages:blog.subtitle")} /><div class="blog-grid" style="margin-top:24px;">{posts.map((post) => <Card class="blog-card"><img src={post.cover} alt={post.title} /><div class="meta-row"><span>{post.publishedAt}</span><span>{post.readMinutes} {uiText.readMinutesUnit}</span></div><h3>{post.title}</h3><p>{post.excerpt}</p><Button href={getPathForRoute(lang, "blog", [post.slug])} variant="ghost">{t("pages:blog.back_to_list")}</Button></Card>)}</div></Shell></section>
        ) : page.routeKey === "dashboard" ? (
            <section class="section"><Shell><SectionHeading badge={t("pages:dashboard.label")} title={t("pages:dashboard.title")} description={t("pages:dashboard.subtitle")} /><div class="dashboard-grid" style="margin-top:24px;"><StatCard class="dashboard-card" title={t("pages:dashboard.current_plan")} value={t("common.loading")} meta={t("common.loading")} data-plan-card><span class="sr-only" data-plan-value>{t("common.loading")}</span><span class="sr-only" data-status-value>{t("common.loading")}</span></StatCard><StatCard class="dashboard-card" title={t("pages:dashboard.monthly_usage")} value="0" meta={t("common.loading")} data-credits-card><span class="sr-only" data-credit-value>0</span><span class="sr-only" data-expiry-value>{t("common.loading")}</span></StatCard><Card class="dashboard-card" tone="highlight"><h3>{t("nav.login")}</h3><div class="action-row"><Button type="button" data-checkout-plan="starter">{t("pages:dashboard.upgrade")}</Button><Button type="button" variant="ghost" data-open-portal>{t("pages:dashboard.manage")}</Button></div></Card></div><Card class="dashboard-card" style="margin-top:24px;"><div class="toolbar"><h2 style="margin-bottom:0;">{t("pages:dashboard.recent_title")}</h2><Button type="button" variant="ghost" data-dashboard-refresh>{t("pages:dashboard.refresh")}</Button></div><p class="muted">{t("pages:dashboard.recent_desc")}</p><div class="examples-grid" data-history-grid></div><EmptyState title={t("pages:dashboard.login_title")} description={t("pages:dashboard.login_desc")} data-login-callout style="margin-top:18px;" hidden><Button href="/api/auth/google">{t("nav.login")}</Button></EmptyState></Card></Shell></section>
            <script is:inline>
                (() => {
                    const historyGrid = document.querySelector("[data-history-grid]");
                    const planCard = document.querySelector("[data-plan-card]");
                    const creditsCard = document.querySelector("[data-credits-card]");
                    const loginCallout = document.querySelector("[data-login-callout]");
                    const refreshButton = document.querySelector("[data-dashboard-refresh]");
                    const setCard = (card, value, meta) => {
                        if (!card) return;
                        const title = card.querySelector("h3")?.outerHTML || "";
                        card.innerHTML = `${title}<strong class="ui-stat-card__value">${value}</strong><p>${meta}</p>`;
                    };
                    const renderHistory = (items) => {
                        if (!historyGrid) return;
                        historyGrid.innerHTML = "";
                        if (!items.length) {
                            historyGrid.innerHTML = `<article class="empty-card ui-card"><h3>${JSON.stringify(String(t("pages:dashboard.empty"))).slice(1, -1)}</h3></article>`;
                            return;
                        }
                        for (const item of items) {
                            const card = document.createElement("article");
                            card.className = "example-card ui-card";
                            card.innerHTML = `<img src="${item.output_url}" alt="${item.prompt || uiText.fallbackPrompt}" loading="lazy" /><figcaption>${item.prompt || item.style || uiText.fallbackName}</figcaption>`;
                            historyGrid.appendChild(card);
                        }
                    };
                    const load = async () => {
                        try {
                            const authResponse = await fetch("/api/auth/me", { credentials: "include" });
                            if (authResponse.status === 401) {
                                loginCallout?.removeAttribute("hidden");
                                renderHistory([]);
                                setCard(planCard, uiText.anonymousPlan, uiText.dashboardAnonymous);
                                setCard(creditsCard, "0", uiText.dashboardNoSession);
                                return;
                            }
                            const auth = await authResponse.json();
                            loginCallout?.setAttribute("hidden", "hidden");
                            const plan = auth.subscription?.plan ? (uiText[`plan${auth.subscription.plan.charAt(0).toUpperCase()}${auth.subscription.plan.slice(1)}`] || auth.subscription.plan) : uiText.defaultPlan;
                            const status = auth.subscription?.status ? (uiText[`status${auth.subscription.status.charAt(0).toUpperCase()}${auth.subscription.status.slice(1)}`] || auth.subscription.status) : uiText.defaultStatus;
                            setCard(planCard, plan, status);
                            setCard(creditsCard, String(auth.credits?.available ?? 0), auth.credits?.expiring_at || uiText.dashboardNoExpiry);
                            const history = await fetch("/api/images/history", { credentials: "include" }).then((res) => res.json());
                            renderHistory(history.items || []);
                        } catch {
                            if (historyGrid) historyGrid.innerHTML = `<article class="empty-card ui-card"><p>${JSON.stringify(uiText.dashboardHistoryError).slice(1, -1)}</p></article>`;
                        }
                    };
                    refreshButton?.addEventListener("click", load);
                    window.addEventListener("chibi-generated", load);
                    load();
                })();
            </script>
        ) : page.routeKey === "admin" ? (
            <section class="section"><Shell><SectionHeading badge={t("pages:admin.label")} title={t("pages:admin.title")} description={t("pages:admin.subtitle")} /><Card class="admin-panel" tone="soft" style="margin-top:24px;"><div class="toolbar"><Button type="button" variant="ghost" data-admin-refresh>{t("pages:admin.refresh")}</Button><span class="muted" data-admin-status>{t("pages:admin.loading")}</span></div><div class="table-wrap" style="margin-top:18px;"><table><thead><tr><th>{t("pages:admin.col_user")}</th><th>{t("pages:admin.col_plan")}</th><th>{t("pages:admin.col_usage")}</th><th>{t("pages:admin.col_registered")}</th><th>{t("pages:admin.col_actions")}</th></tr></thead><tbody data-admin-body></tbody></table></div></Card></Shell></section>
            <script is:inline>
                (() => {
                    const body = document.querySelector("[data-admin-body]");
                    const status = document.querySelector("[data-admin-status]");
                    const refresh = document.querySelector("[data-admin-refresh]");
                    const render = (items) => {
                        if (!body) return;
                        body.innerHTML = "";
                        if (!items.length) {
                            body.innerHTML = `<tr><td colspan="5">${JSON.stringify(String(t("pages:admin.no_users"))).slice(1, -1)}</td></tr>`;
                            return;
                        }
                        for (const item of items) {
                            const tr = document.createElement("tr");
                            tr.innerHTML = `<td>${item.name || item.email || uiText.adminUnnamed}</td><td><select class="ui-select" data-plan-select><option value="free" ${item.plan === "free" ? "selected" : ""}>${uiText.adminPlanFree}</option><option value="starter" ${item.plan === "starter" ? "selected" : ""}>${uiText.adminPlanStarter}</option><option value="standard" ${item.plan === "standard" ? "selected" : ""}>${uiText.adminPlanStandard}</option><option value="value" ${item.plan === "value" ? "selected" : ""}>${uiText.adminPlanValue}</option></select></td><td>${item.credits} ${uiText.adminCreditsLabel} / ${item.total_images} ${uiText.adminImageUnit}</td><td>${item.created_at}</td><td><div class="action-row"><input class="ui-input" type="number" value="10" step="1" style="max-width:100px;" /><button class="ui-button ui-button--ghost" data-fill>${JSON.stringify(String(t("pages:admin.credits_btn"))).slice(1, -1)}</button><button class="ui-button ui-button--primary" data-set-plan>${JSON.stringify(String(t("pages:admin.plan_btn"))).slice(1, -1)}</button></div></td>`;
                            const amountInput = tr.querySelector("input");
                            const planSelect = tr.querySelector("select");
                            tr.querySelector("[data-fill]")?.addEventListener("click", async () => {
                                await fetch("/api/admin/fill-credits", { method: "POST", headers: { "Content-Type": "application/json" }, body: JSON.stringify({ userId: item.id, amount: Number(amountInput?.value || 0) }) });
                                load();
                            });
                            tr.querySelector("[data-set-plan]")?.addEventListener("click", async () => {
                                await fetch("/api/admin/set-plan", { method: "POST", headers: { "Content-Type": "application/json" }, body: JSON.stringify({ userId: item.id, plan: planSelect?.value || "free" }) });
                                load();
                            });
                            body.appendChild(tr);
                        }
                    };
                    const load = async () => {
                        if (status) status.textContent = ${JSON.stringify(String(t("pages:admin.refreshing")))};
                        const response = await fetch("/api/admin/users", { credentials: "include" });
                        if (!response.ok) {
                            if (status) status.textContent = response.status === 403 ? uiText.adminAccessRequired : ${JSON.stringify(String(t("pages:admin.load_failed")))};
                            render([]);
                            return;
                        }
                        const payload = await response.json();
                        render(payload.items || []);
                        if (status) status.textContent = `${payload.items?.length || 0} ${uiText.adminStatusUsers}`;
                    };
                    refresh?.addEventListener("click", load);
                    load();
                })();
            </script>
        ) : null
    }

    <script is:inline>
        (() => {
            const message = document.querySelector("[data-payment-message]");
            const setMessage = (value) => {
                if (!message) return;
                message.hidden = !value;
                message.textContent = value || "";
            };
            document.querySelectorAll("[data-checkout-plan]").forEach((button) => {
                button.addEventListener("click", async () => {
                    const plan = button.getAttribute("data-checkout-plan");
                    if (!plan) return;
                    setMessage(uiText.paymentLoadingCheckout);
                    const response = await fetch("/api/payments/create-checkout", { method: "POST", headers: { "Content-Type": "application/json" }, body: JSON.stringify({ plan }) });
                    const payload = await response.json();
                    if (!response.ok) {
                        setMessage(payload.error || uiText.paymentCheckoutFailed);
                        return;
                    }
                    window.location.href = payload.url;
                });
            });
            document.querySelectorAll("[data-open-portal]").forEach((button) => {
                button.addEventListener("click", async () => {
                    const response = await fetch("/api/payments/create-portal", { method: "POST" });
                    const payload = await response.json();
                    if (!response.ok) {
                        alert(payload.error || uiText.paymentPortalFailed);
                        return;
                    }
                    window.location.href = payload.url;
                });
            });
        })();
    </script>
</Base>
