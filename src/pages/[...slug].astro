---
import Base from "@/layouts/Base.astro";
import GeneratorPanel from "@/components/GeneratorPanel.astro";
import Button from "@/components/ui/Button.astro";
import Card from "@/components/ui/Card.astro";
import EmptyState from "@/components/ui/EmptyState.astro";
import SectionHeading from "@/components/ui/SectionHeading.astro";
import Shell from "@/components/ui/Shell.astro";
import StatCard from "@/components/ui/StatCard.astro";
import { routes } from "@/i18n/routes";
import { useTranslatedPath, useTranslations } from "@/i18n/utils";
import { exampleGroups, getBlogPost, getBlogPosts } from "@/lib/site/content";
import { pricingCards } from "@/lib/site/plans";
import { getPathForRoute, getRoutedPage } from "@/lib/site/router";
import { getStats } from "@/lib/server/generation/service";
import { ensureAppReady } from "@/lib/server/startup";

await ensureAppReady();

const page = getRoutedPage(Astro.url);
const lang = page.lang;
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);
const availableKeys = new Set(Object.keys(routes[lang]));
const isKnownRoute = availableKeys.has(page.routeKey);
const stats = await getStats();

const faqItems = (key: string) => (t(key) as Array<{ q: string; a: string }>) ?? [];
const pageTitleByRoute: Record<string, string> = {
    home: String(t("pages:index.hero_title")),
    "photo-to-chibi": String(t("pages:photo-to-chibi.title")),
    "chibi-avatar-maker": String(t("pages:chibi-avatar-maker.title")),
    "chibi-couple-generator": String(t("pages:chibi-couple-generator.title")),
    pricing: String(t("pages:pricing.title")),
    features: String(t("pages:features.title")),
    about: String(t("pages:about.title")),
    dashboard: String(t("pages:dashboard.title")),
    admin: String(t("pages:admin.title")),
    blog: String(t("pages:blog.title")),
};
const pageDescriptionByRoute: Record<string, string> = {
    home: String(t("pages:index.hero_subtitle")),
    "photo-to-chibi": String(t("pages:photo-to-chibi.hero_subtitle")),
    "chibi-avatar-maker": String(t("pages:chibi-avatar-maker.hero_subtitle")),
    "chibi-couple-generator": String(t("pages:chibi-couple-generator.hero_subtitle")),
    pricing: String(t("pages:pricing.subtitle")),
    features: String(t("pages:features.subtitle")),
    about: String(t("pages:about.para1")),
    dashboard: String(t("pages:dashboard.subtitle")),
    admin: String(t("pages:admin.subtitle")),
    blog: String(t("pages:blog.subtitle")),
};

let render404 = page.isApi ? false : !isKnownRoute;
let blogPost = null;
if (!render404 && page.isBlogDetail) {
    blogPost = getBlogPost(lang, page.rest[0] ?? "");
    if (!blogPost) {
        render404 = true;
    }
}
if (render404) {
    Astro.response.status = 404;
}

const styleCards = [1, 2, 3, 4].map((item) => ({
    title: t(`pages:index.index_styles.item${item}_title`),
    body: t(`pages:index.index_styles.item${item}_body`),
}));
const tipCards = [1, 2, 3, 4].map((item) => ({
    title: t(`pages:index.index_tips.item${item}_title`),
    body: t(`pages:index.index_tips.item${item}_body`),
}));
const infoCards = [1, 2, 3].map((item) => ({
    title: t(`pages:index.index_info.item${item}_title`),
    body: t(`pages:index.index_info.item${item}_body`),
}));
const featureBlocks = [1, 2, 3, 4, 5, 6].map((item) => ({
    title: t(`pages:features.card${item}_title`),
    body: t(`pages:features.card${item}_desc`),
}));
const aboutValues = [1, 2, 3].map((item) => ({
    title: t(`pages:about.value${item}_title`),
    body: t(`pages:about.value${item}_desc`),
}));
const photoSteps = [1, 2, 3, 4].map((item) => ({
    title: t(`pages:photo-to-chibi.step${item}_title`),
    body: t(`pages:photo-to-chibi.step${item}_body`),
}));
const photoTips = [1, 2, 3, 4].map((item) => ({
    title: t(`pages:photo-to-chibi.tip${item}_title`),
    body: t(`pages:photo-to-chibi.tip${item}_body`),
}));
const avatarSteps = [1, 2, 3, 4].map((item) => ({
    title: t(`pages:chibi-avatar-maker.step${item}_title`),
    body: t(`pages:chibi-avatar-maker.step${item}_body`),
}));
const avatarIdeas = [1, 2, 3].map((item) => ({
    title: t(`pages:chibi-avatar-maker.avatar_ideas.item${item}_title`),
    body: t(`pages:chibi-avatar-maker.avatar_ideas.item${item}_body`),
}));
const avatarPerfectFor = [1, 2, 3].map((item) => ({
    title: t(`pages:chibi-avatar-maker.avatar_perfect_for.item${item}_title`),
    body: t(`pages:chibi-avatar-maker.avatar_perfect_for.item${item}_body`),
}));
const coupleSteps = [1, 2, 3, 4].map((item) => ({
    title: t(`pages:chibi-couple-generator.step${item}_title`),
    body: t(`pages:chibi-couple-generator.step${item}_body`),
}));
const coupleTips = [1, 2, 3].map((item) => ({
    title: t(`pages:chibi-couple-generator.tip${item}_title`),
    body: t(`pages:chibi-couple-generator.tip${item}_body`),
}));
const posts = getBlogPosts(lang);
const featuredPricingCard = pricingCards.find((card) => card.featured) ?? pricingCards[0];
const homePreviewExamples = exampleGroups.home.slice(0, 3);
const testimonials = [1, 2, 3].map((item) => ({
    name: String(t(`testimonials.item${item}_name`)),
    role: String(t(`testimonials.item${item}_role`)),
    quote: String(t(`testimonials.item${item}_quote`)),
}));
const toolFooterLinks = [
    { label: t("nav.photo"), href: getPathForRoute(lang, "photo-to-chibi") },
    { label: t("nav.avatar"), href: getPathForRoute(lang, "chibi-avatar-maker") },
    { label: t("nav.couple"), href: getPathForRoute(lang, "chibi-couple-generator") },
];
const uiText = {
    ctaGenerate: String(t("cta.title")),
    statTotalGenerated: String(t("metrics.total_generated")),
    statTodayGenerated: String(t("metrics.generated_today")),
    statStyles: String(t("metrics.style_count")),
    readMinutesUnit: String(t("common.read_minutes_unit")),
    userUnit: String(t("common.user_unit")),
    imageUnit: String(t("common.image_unit")),
    fallbackName: String(t("dashboard.fallback_name")),
    fallbackPrompt: String(t("dashboard.fallback_name")),
    anonymousPlan: String(t("plan.free")),
    defaultPlan: String(t("plan.free")),
    defaultStatus: String(t("payment.status.active")),
    planFree: String(t("plan.free")),
    planStarter: String(t("plan.starter")),
    planStandard: String(t("plan.standard")),
    planValue: String(t("plan.value")),
    statusActive: String(t("payment.status.active")),
    statusCancelling: String(t("payment.status.cancelling")),
    dashboardAnonymous: String(t("dashboard.status_anonymous")),
    dashboardNoSession: String(t("dashboard.no_session")),
    dashboardNoExpiry: String(t("dashboard.no_expiry")),
    dashboardHistoryError: String(t("dashboard.load_error")),
    dashboardEmpty: String(t("pages:dashboard.empty")),
    adminAccessRequired: String(t("admin.access_required")),
    adminStatusUsers: String(t("common.user_unit")),
    adminRefreshing: String(t("pages:admin.refreshing")),
    adminLoadFailed: String(t("pages:admin.load_failed")),
    adminNoUsers: String(t("pages:admin.no_users")),
    adminCreditsLabel: String(t("pages:admin.credits_btn")),
    adminCreditsButton: String(t("pages:admin.credits_btn")),
    adminImageUnit: String(t("common.image_unit")),
    adminPlanFree: String(t("plan.free")),
    adminPlanStarter: String(t("plan.starter")),
    adminPlanStandard: String(t("plan.standard")),
    adminPlanValue: String(t("plan.value")),
    adminPlanButton: String(t("pages:admin.plan_btn")),
    adminUnnamed: String(t("pages:admin.unnamed")),
    paymentLoadingCheckout: String(t("payment.loading_checkout")),
    paymentCheckoutFailed: String(t("payment.checkout_failed")),
    paymentPortalFailed: String(t("payment.portal_failed")),
};

const sectionBase = "py-10 md:py-12 lg:py-[84px]";
const softSection = "py-10 md:py-12 lg:py-[84px] bg-[var(--surface-band-soft)]";
const neutralSection = "py-10 md:py-12 lg:py-[84px] bg-[var(--surface-band-neutral)]";
const generatorSection = "py-10 md:py-12 lg:py-[84px] bg-[var(--surface-band-generator)]";
const faqSection = "py-10 md:py-12 lg:py-[84px] bg-[linear-gradient(180deg,#f8fafc_0%,#eef4fb_100%)]";
const heroHome = "relative bg-[var(--surface-band-hero)] pb-6 pt-16 md:pt-[74px]";
const heroTool = "relative bg-[linear-gradient(180deg,#f8fbff_0%,#eef5ff_100%)] pb-6 pt-16 md:pt-[74px]";
const heroPricing = "relative bg-[linear-gradient(180deg,#f8fbff_0%,#eef3fb_100%)] pb-6 pt-16 md:pt-[74px]";
const heroSplitGrid = "grid gap-6 xl:grid-cols-2";
const twoColumnGrid = "grid gap-6 lg:grid-cols-[minmax(280px,0.8fr)_minmax(0,1.2fr)]";
const contentGrid = "grid gap-[18px] md:grid-cols-2 xl:grid-cols-3";
const featureGrid = "grid gap-[18px] md:grid-cols-2 xl:grid-cols-4";
const featureRailGrid = "grid gap-[18px] md:grid-cols-2 xl:grid-cols-3 xl:auto-rows-fr";
const proofGrid = "grid gap-[18px] md:grid-cols-3";
const miniGrid = "grid gap-[18px] md:grid-cols-2";
const showcaseGrid = "grid gap-4 md:grid-cols-3";
const pricingCardsGrid = "grid gap-[18px] md:grid-cols-2 xl:grid-cols-4";
const exploreGrid = "grid gap-5 md:grid-cols-2 xl:grid-cols-3";
const listGrid = "grid gap-[18px] md:grid-cols-2 xl:grid-cols-3";
const eyebrowClass = "inline-flex min-h-8 w-fit items-center gap-2 rounded-full border border-[var(--badge-border)] bg-[var(--badge-bg)] px-3.5 py-1.5 text-xs font-semibold uppercase tracking-[0.04em] text-[var(--badge-fg)]";
const indexClass = "inline-flex w-fit items-center justify-center text-[0.78rem] font-bold uppercase tracking-[0.08em] text-[var(--primary)]";
const exploreCardClass = "grid min-h-[13rem] content-between gap-4 rounded-[22px] border border-[rgba(148,163,184,0.18)] bg-[linear-gradient(180deg,#ffffff_0%,#f8fbff_100%)] p-[1.45rem] text-[var(--text-strong)] no-underline shadow-[0_14px_28px_rgba(15,23,42,0.06)] transition duration-200 ease-out hover:-translate-y-0.5 hover:border-[rgba(37,99,235,0.24)] hover:shadow-[0_18px_36px_rgba(37,99,235,0.18)]";
const showcaseCardClass = "overflow-hidden rounded-[18px] border border-[var(--card-border)] bg-[var(--surface-raised)] shadow-[var(--card-shadow)] transition duration-200 ease-out hover:-translate-y-0.5 hover:border-[rgba(37,99,235,0.22)] hover:shadow-[var(--card-shadow-hover)]";
const summaryItemClass = "flex items-start justify-between gap-4 rounded-[18px] border border-[rgba(148,163,184,0.16)] bg-[rgba(255,255,255,0.64)] px-[1.1rem] py-4";

const metaTitle = render404
    ? String(t("error_404_title"))
    : page.isBlogDetail && blogPost
      ? blogPost.title
      : pageTitleByRoute[page.routeKey] ?? "AI Chibi Generator";
const metaDescription = render404
    ? String(t("error_404_desc"))
    : page.isBlogDetail && blogPost
      ? blogPost.excerpt
      : pageDescriptionByRoute[page.routeKey] ?? "AI Chibi Generator";
---

<Base title={metaTitle} meta={{ description: metaDescription, canonical: Astro.url.href, robots: render404 ? "noindex,nofollow" : "index,follow" }}>
    {
        render404 ? (
            <section class={sectionBase}>
                <Shell>
                    <EmptyState title={String(t("error_404_title"))} description={String(t("error_404_desc"))}>
                        <div class="flex flex-wrap items-center justify-center gap-3">
                            <Button href={getPathForRoute(lang, "home")}>{String(t("error_back_home"))}</Button>
                        </div>
                    </EmptyState>
                </Shell>
            </section>
        ) : page.routeKey === "home" ? (
            <>
                <section class={heroHome}>
                    <Shell>
                        <div class={heroSplitGrid}>
                            <div class="grid content-start gap-4">
                                <span class={eyebrowClass}>{t("pages:index.hero_badge")}</span>
                                <h1 class="mb-0 max-w-[10ch]">{t("pages:index.hero_title")}</h1>
                                <p class="text-[1.06rem] text-[var(--text-muted)]">{t("pages:index.hero_subtitle")}</p>
                                <div class="flex flex-wrap items-center gap-3">
                                    <Button href="#route-generator">{uiText.ctaGenerate}</Button>
                                    <Button href={translatePath("/pricing")} variant="ghost">{t("nav.pricing")}</Button>
                                </div>
                                <div class={proofGrid}>
                                    <Card class="grid gap-2" tone="soft">
                                        <strong class="block text-[clamp(2rem,3vw,2.6rem)] leading-none tracking-[-0.04em] text-[var(--text-strong)]">{stats.total}</strong>
                                        <span class="text-sm text-[var(--text-muted)]">{uiText.statTotalGenerated}</span>
                                    </Card>
                                    <Card class="grid gap-2" tone="soft">
                                        <strong class="block text-[clamp(2rem,3vw,2.6rem)] leading-none tracking-[-0.04em] text-[var(--text-strong)]">{stats.today}</strong>
                                        <span class="text-sm text-[var(--text-muted)]">{uiText.statTodayGenerated}</span>
                                    </Card>
                                    <Card class="grid gap-2" tone="soft">
                                        <strong class="block text-[clamp(2rem,3vw,2.6rem)] leading-none tracking-[-0.04em] text-[var(--text-strong)]">{Object.keys(stats.styles).length}</strong>
                                        <span class="text-sm text-[var(--text-muted)]">{uiText.statStyles}</span>
                                    </Card>
                                </div>
                            </div>

                            <div class="grid gap-5">
                                <Card class="grid gap-5" tone="highlight">
                                    <SectionHeading title={t("pages:index.recent_title")} description={t("pages:index.recent_desc")} />
                                    <div class={proofGrid}>
                                        <StatCard value={stats.total} meta={uiText.statTotalGenerated} />
                                        <StatCard value={stats.today} meta={uiText.statTodayGenerated} />
                                        <StatCard value={Object.keys(stats.styles).length} meta={uiText.statStyles} />
                                    </div>
                                    <div class={showcaseGrid}>
                                        {
                                            homePreviewExamples.map((example) => (
                                                <figure class={showcaseCardClass}>
                                                    <img
                                                        src={example.image}
                                                        alt={typeof example.alt === "string" ? example.alt : example.alt[lang] ?? example.alt.en}
                                                        loading="lazy"
                                                        class="aspect-square w-full object-cover"
                                                    />
                                                    <figcaption class="px-4 pb-4 pt-3 text-sm font-semibold text-[var(--text-strong)]">
                                                        {typeof example.title === "string" ? example.title : example.title[lang] ?? example.title.en}
                                                    </figcaption>
                                                </figure>
                                            ))
                                        }
                                    </div>
                                </Card>
                                <div class={miniGrid}>
                                    {
                                        infoCards.slice(0, 2).map((card, index) => (
                                            <Card class="grid gap-3" tone={index === 0 ? "soft" : "default"}>
                                                <span class={indexClass}>0{index + 1}</span>
                                                <h3>{card.title}</h3>
                                                <p>{card.body}</p>
                                            </Card>
                                        ))
                                    }
                                </div>
                            </div>
                        </div>
                    </Shell>
                </section>

                <section class={generatorSection} id="route-generator">
                    <Shell>
                        <div class="grid gap-6">
                            <SectionHeading badge={t("pages:index.recent_title")} title={uiText.ctaGenerate} description={t("pages:index.recent_desc")} />
                            <GeneratorPanel
                                formId={`generator-${lang}`}
                                labels={{
                                    prompt: String(t("pages:index.label_prompt")),
                                    promptPlaceholder: String(t("pages:index.prompt_placeholder")),
                                    photo: String(t("pages:index.label_photo")),
                                    photoHelp: String(t("pages:index.photo_help")),
                                    style: String(t("pages:index.label_style")),
                                    styleHelp: String(t("pages:index.style_help")),
                                    submit: String(t("cta.title")),
                                    generating: String(t("common.generating")),
                                    resultTitle: String(t("pages:index.result_title")),
                                    resultDesc: String(t("pages:index.result_desc")),
                                    download: String(t("common.download")),
                                    tryAgain: String(t("common.try_again")),
                                }}
                                lang={lang}
                                examples={exampleGroups.home}
                            />
                        </div>
                    </Shell>
                </section>

                <section class={sectionBase}>
                    <Shell>
                        <div class={twoColumnGrid}>
                            <SectionHeading title={t("pages:index.index_styles.title")} description={t("pages:index.index_styles.description")} />
                            <div class={featureRailGrid}>
                                {
                                    styleCards.map((card, index) => (
                                        <Card tone={index === 1 ? "highlight" : index === 2 ? "soft" : "default"} class="grid gap-3">
                                            <span class={indexClass}>0{index + 1}</span>
                                            <h3>{card.title}</h3>
                                            <p>{card.body}</p>
                                        </Card>
                                    ))
                                }
                            </div>
                        </div>
                    </Shell>
                </section>

                <section class={sectionBase}>
                    <Shell>
                        <div class="grid gap-6 xl:grid-cols-2">
                            <Card class="grid gap-5" tone="soft">
                                <SectionHeading title={t("pages:index.index_tips.title")} description={t("pages:index.index_tips.description")} />
                                <div class="grid gap-4">
                                    {
                                        tipCards.map((card, index) => (
                                            <article class="grid grid-cols-[auto_minmax(0,1fr)] gap-4">
                                                <span class={indexClass}>0{index + 1}</span>
                                                <div>
                                                    <h3>{card.title}</h3>
                                                    <p>{card.body}</p>
                                                </div>
                                            </article>
                                        ))
                                    }
                                </div>
                            </Card>
                            <div class="grid gap-[18px] md:grid-cols-2">
                                {
                                    infoCards.map((card) => (
                                        <Card>
                                            <h3>{card.title}</h3>
                                            <p>{card.body}</p>
                                        </Card>
                                    ))
                                }
                            </div>
                        </div>
                    </Shell>
                </section>

                <section class={faqSection}>
                    <Shell>
                        <div class="grid gap-6">
                            <SectionHeading title={t("pages:index.faq_title")} description={t("pages:index.recent_desc")} />
                            <div class={listGrid}>
                                {faqItems("pages:index.faq_items").map((item) => <Card class="bg-[linear-gradient(180deg,#ffffff_0%,#f8fafc_100%)]"><h3>{item.q}</h3><p>{item.a}</p></Card>)}
                            </div>
                        </div>
                    </Shell>
                </section>
            </>
        ) : page.routeKey === "photo-to-chibi" ? (
            <>
                <section class={heroTool}>
                    <Shell>
                        <div class={heroSplitGrid}>
                            <div class="grid content-start gap-4">
                                <span class={eyebrowClass}>{t("pages:photo-to-chibi.hero_badge")}</span>
                                <h1 class="mb-0 max-w-[11ch]">{t("pages:photo-to-chibi.title")}</h1>
                                <p class="text-[1.06rem] text-[var(--text-muted)]">{t("pages:photo-to-chibi.hero_subtitle")}</p>
                                <div class="flex flex-wrap items-center gap-3">
                                    <Button href="#route-generator">{t("pages:photo-to-chibi.generate_btn")}</Button>
                                </div>
                            </div>
                            <div class={miniGrid}>
                                {
                                    photoTips.slice(0, 3).map((tip, index) => (
                                        <Card class="grid gap-3" tone={index === 1 ? "soft" : "default"}>
                                            <h3>{tip.title}</h3>
                                            <p>{tip.body}</p>
                                        </Card>
                                    ))
                                }
                            </div>
                        </div>
                    </Shell>
                </section>

                <section class={generatorSection} id="route-generator">
                    <Shell>
                        <GeneratorPanel
                            formId={`photo-generator-${lang}`}
                            labels={{
                                prompt: String(t("pages:photo-to-chibi.label_notes")),
                                promptPlaceholder: String(t("pages:photo-to-chibi.notes_placeholder")),
                                photo: String(t("pages:photo-to-chibi.label_photo")),
                                photoHelp: String(t("pages:photo-to-chibi.photo_help")),
                                style: String(t("pages:index.label_style")),
                                styleHelp: String(t("pages:photo-to-chibi.style_help")),
                                submit: String(t("pages:photo-to-chibi.generate_btn")),
                                generating: String(t("common.generating")),
                                resultTitle: String(t("pages:photo-to-chibi.result_title")),
                                resultDesc: String(t("pages:index.result_desc")),
                                download: String(t("common.download")),
                                tryAgain: String(t("common.try_again")),
                            }}
                            defaults={{ style: "avatar" }}
                            lang={lang}
                            examples={exampleGroups.photo}
                        />
                    </Shell>
                </section>

                <section class={neutralSection}>
                    <Shell>
                        <div class={twoColumnGrid}>
                            <SectionHeading title={t("nav.features")} description={t("pages:photo-to-chibi.tips_title")} />
                            <div class={contentGrid}>
                                {photoTips.map((tip) => <Card><h3>{tip.title}</h3><p>{tip.body}</p></Card>)}
                            </div>
                        </div>
                    </Shell>
                </section>

                <section class={softSection}>
                    <Shell>
                        <SectionHeading title={t("pages:photo-to-chibi.how_it_works_title")} />
                        <div class={`mt-6 ${featureGrid}`}>
                            {photoSteps.map((step, index) => <Card class="grid gap-3"><span class={indexClass}>0{index + 1}</span><h3>{step.title}</h3><p>{step.body}</p></Card>)}
                        </div>
                    </Shell>
                </section>

                <section class={neutralSection}>
                    <Shell>
                        <SectionHeading title={t("nav.pricing")} description={t(`pages:pricing.${featuredPricingCard.id}_desc`)} />
                        <div class={`mt-6 ${pricingCardsGrid}`}>
                            {
                                pricingCards.map((card) => (
                                    <Card tone={card.featured ? "highlight" : "default"} class="grid gap-4">
                                        <span class={eyebrowClass}>{card.featured ? t("pages:pricing.popular") : t(`plan.${card.id}`)}</span>
                                        <h3>{t(`pages:pricing.${card.id}_title`)}</h3>
                                        <p>{t(`pages:pricing.${card.id}_desc`)}</p>
                                        <strong class="block text-[clamp(2rem,3vw,2.6rem)] leading-none tracking-[-0.04em] text-[var(--text-strong)]">{card.priceLabel}</strong>
                                        <p>{card.creditLabel ?? t(`pages:pricing.${card.id}_credit`)}</p>
                                        {card.featureKeys && <ul class="m-0 pl-5">{card.featureKeys.map((key) => <li>{t(key)}</li>)}</ul>}
                                    </Card>
                                ))
                            }
                        </div>
                    </Shell>
                </section>

                <section class={softSection}>
                    <Shell>
                        <SectionHeading title={t("testimonials.title")} description={t("testimonials.description")} />
                        <div class={`mt-6 ${contentGrid}`}>
                            {testimonials.map((item) => <Card class="grid gap-4"><p class="text-[1.05rem] leading-[1.75]">"{item.quote}"</p><div><h3 class="mb-1">{item.name}</h3><p>{item.role}</p></div></Card>)}
                        </div>
                    </Shell>
                </section>

                <section class={faqSection}>
                    <Shell>
                        <div class="grid gap-6">
                            <SectionHeading title={t("pages:photo-to-chibi.photo_faq_title")} />
                            <div class={listGrid}>
