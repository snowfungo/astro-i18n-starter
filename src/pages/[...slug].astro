---
import Base from "@/layouts/Base.astro";
import GeneratorPanel from "@/components/GeneratorPanel.astro";
import { routes } from "@/i18n/routes";
import { useTranslatedPath, useTranslations } from "@/i18n/utils";
import { exampleGroups, getBlogPost, getBlogPosts } from "@/lib/site/content";
import { getStats } from "@/lib/server/generation/service";
import { ensureAppReady } from "@/lib/server/startup";
import { pricingCards } from "@/lib/site/plans";
import { getPathForRoute, getRoutedPage } from "@/lib/site/router";

await ensureAppReady();

const page = getRoutedPage(Astro.url);
const lang = page.lang;
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);
const availableKeys = new Set(Object.keys(routes[lang]));
const isKnownRoute = availableKeys.has(page.routeKey);
const stats = await getStats();

const faqItems = (key: string) => (t(key) as Array<{ q: string; a: string }>) ?? [];
const pageTitleByRoute: Record<string, string> = {
    home: String(t("pages:index.hero_title")),
    "photo-to-chibi": String(t("pages:photo-to-chibi.title")),
    "chibi-avatar-maker": String(t("pages:chibi-avatar-maker.title")),
    "chibi-couple-generator": String(t("pages:chibi-couple-generator.title")),
    pricing: String(t("pages:pricing.title")),
    features: String(t("pages:features.title")),
    about: String(t("pages:about.title")),
    dashboard: String(t("pages:dashboard.title")),
    admin: String(t("pages:admin.title")),
    blog: String(t("pages:blog.title")),
};
const pageDescriptionByRoute: Record<string, string> = {
    home: String(t("pages:index.hero_subtitle")),
    "photo-to-chibi": String(t("pages:photo-to-chibi.hero_subtitle")),
    "chibi-avatar-maker": String(t("pages:chibi-avatar-maker.hero_subtitle")),
    "chibi-couple-generator": String(t("pages:chibi-couple-generator.hero_subtitle")),
    pricing: String(t("pages:pricing.subtitle")),
    features: String(t("pages:features.subtitle")),
    about: String(t("pages:about.para1")),
    dashboard: String(t("pages:dashboard.subtitle")),
    admin: String(t("pages:admin.subtitle")),
    blog: String(t("pages:blog.subtitle")),
};

let render404 = page.isApi ? false : !isKnownRoute;
let blogPost = null;
if (!render404 && page.isBlogDetail) {
    blogPost = getBlogPost(lang, page.rest[0] ?? "");
    if (!blogPost) {
        render404 = true;
    }
}
if (render404) {
    Astro.response.status = 404;
}

const styleCards = [1, 2, 3, 4].map((item) => ({
    title: t(`pages:index.index_styles.item${item}_title`),
    body: t(`pages:index.index_styles.item${item}_body`),
}));
const tipCards = [1, 2, 3, 4].map((item) => ({
    title: t(`pages:index.index_tips.item${item}_title`),
    body: t(`pages:index.index_tips.item${item}_body`),
}));
const infoCards = [1, 2, 3].map((item) => ({
    title: t(`pages:index.index_info.item${item}_title`),
    body: t(`pages:index.index_info.item${item}_body`),
}));
const featureBlocks = [1, 2, 3, 4, 5, 6].map((item) => ({
    title: t(`pages:features.card${item}_title`),
    body: t(`pages:features.card${item}_desc`),
}));
const aboutValues = [1, 2, 3].map((item) => ({
    title: t(`pages:about.value${item}_title`),
    body: t(`pages:about.value${item}_desc`),
}));
const photoSteps = [1, 2, 3, 4].map((item) => ({
    title: t(`pages:photo-to-chibi.step${item}_title`),
    body: t(`pages:photo-to-chibi.step${item}_body`),
}));
const photoTips = [1, 2, 3, 4].map((item) => ({
    title: t(`pages:photo-to-chibi.tip${item}_title`),
    body: t(`pages:photo-to-chibi.tip${item}_body`),
}));
const avatarSteps = [1, 2, 3, 4].map((item) => ({
    title: t(`pages:chibi-avatar-maker.step${item}_title`),
    body: t(`pages:chibi-avatar-maker.step${item}_body`),
}));
const avatarIdeas = [1, 2, 3].map((item) => ({
    title: t(`pages:chibi-avatar-maker.avatar_ideas.item${item}_title`),
    body: t(`pages:chibi-avatar-maker.avatar_ideas.item${item}_body`),
}));
const avatarPerfectFor = [1, 2, 3].map((item) => ({
    title: t(`pages:chibi-avatar-maker.avatar_perfect_for.item${item}_title`),
    body: t(`pages:chibi-avatar-maker.avatar_perfect_for.item${item}_body`),
}));
const coupleSteps = [1, 2, 3, 4].map((item) => ({
    title: t(`pages:chibi-couple-generator.step${item}_title`),
    body: t(`pages:chibi-couple-generator.step${item}_body`),
}));
const coupleTips = [1, 2, 3].map((item) => ({
    title: t(`pages:chibi-couple-generator.tip${item}_title`),
    body: t(`pages:chibi-couple-generator.tip${item}_body`),
}));
const posts = getBlogPosts(lang);
const uiText = {
    ctaGenerate: String(t("cta.title")),
    statTotalGenerated: String(t("metrics.total_generated")),
    statTodayGenerated: String(t("metrics.generated_today")),
    statStyles: String(t("metrics.style_count")),
    readMinutesUnit: String(t("common.read_minutes_unit")),
    userUnit: String(t("common.user_unit")),
    imageUnit: String(t("common.image_unit")),
    fallbackName: String(t("dashboard.fallback_name")),
    fallbackPrompt: String(t("dashboard.fallback_name")),
    anonymousPlan: String(t("plan.free")),
    defaultPlan: String(t("plan.free")),
    defaultStatus: String(t("payment.status.active")),
    planFree: String(t("plan.free")),
    planStarter: String(t("plan.starter")),
    planStandard: String(t("plan.standard")),
    planValue: String(t("plan.value")),
    statusActive: String(t("payment.status.active")),
    statusCancelling: String(t("payment.status.cancelling")),
    dashboardAnonymous: String(t("dashboard.status_anonymous")),
    dashboardNoSession: String(t("dashboard.no_session")),
    dashboardNoExpiry: String(t("dashboard.no_expiry")),
    dashboardHistoryError: String(t("dashboard.load_error")),
    adminAccessRequired: String(t("admin.access_required")),
    adminStatusUsers: String(t("common.user_unit")),
    adminCreditsLabel: String(t("pages:admin.credits_btn")),
    adminImageUnit: String(t("common.image_unit")),
    adminPlanFree: String(t("plan.free")),
    adminPlanStarter: String(t("plan.starter")),
    adminPlanStandard: String(t("plan.standard")),
    adminPlanValue: String(t("plan.value")),
    adminUnnamed: String(t("pages:admin.unnamed")),
    paymentLoadingCheckout: String(t("payment.loading_checkout")),
    paymentCheckoutFailed: String(t("payment.checkout_failed")),
    paymentPortalFailed: String(t("payment.portal_failed")),
};
const metaTitle = render404
    ? String(t("error_404_title"))
    : page.isBlogDetail && blogPost
      ? blogPost.title
      : pageTitleByRoute[page.routeKey] ?? "AI Chibi Generator";
const metaDescription = render404
    ? String(t("error_404_desc"))
    : page.isBlogDetail && blogPost
      ? blogPost.excerpt
      : pageDescriptionByRoute[page.routeKey] ?? "AI Chibi Generator";
---

<Base title={metaTitle} meta={{ description: metaDescription, canonical: Astro.url.href, robots: render404 ? "noindex,nofollow" : "index,follow" }}>
    {
        render404 ? (
            <section class="section">
                <div class="shell empty-card">
                    <span class="eyebrow">404</span>
                    <h1>{String(t("error_404_title"))}</h1>
                    <p>{String(t("error_404_desc"))}</p>
                    <div class="action-row">
                        <a class="primary-button" href={getPathForRoute(lang, "home")}>{String(t("error_back_home"))}</a>
                    </div>
                </div>
            </section>
        ) : page.routeKey === "home" ? (
            <>
                <section class="hero">
                    <div class="shell hero-grid">
                        <div class="hero-copy">
                            <span class="eyebrow">{t("pages:index.hero_badge")}</span>
                            <h1>{t("pages:index.hero_title")}</h1>
                            <p>{t("pages:index.hero_subtitle")}</p>
                            <div class="action-row">
                                <a class="primary-button" href="#route-generator">{uiText.ctaGenerate}</a>
                                <a class="ghost-button" href={translatePath("/pricing")}>{t("nav.pricing")}</a>
                            </div>
                        </div>
                        <div class="hero-panel">
                            <h2>{t("pages:index.recent_title")}</h2>
                            <p>{t("pages:index.recent_desc")}</p>
                            <div class="stat-grid" style="margin-top:18px;">
                                <article class="stat-card"><strong>{stats.total}</strong><p>{uiText.statTotalGenerated}</p></article>
                                <article class="stat-card"><strong>{stats.today}</strong><p>{uiText.statTodayGenerated}</p></article>
                                <article class="stat-card"><strong>{Object.keys(stats.styles).length}</strong><p>{uiText.statStyles}</p></article>
                            </div>
                        </div>
                    </div>
                </section>
                <div class="shell" id="route-generator">
                    <GeneratorPanel formId={`generator-${lang}`} labels={{ prompt: String(t("pages:index.label_prompt")), promptPlaceholder: String(t("pages:index.prompt_placeholder")), photo: String(t("pages:index.label_photo")), photoHelp: String(t("pages:index.photo_help")), style: String(t("pages:index.label_style")), styleHelp: String(t("pages:index.style_help")), submit: String(t("cta.title")), generating: String(t("common.generating")), resultTitle: String(t("pages:index.result_title")), resultDesc: String(t("pages:index.result_desc")), download: String(t("common.download")), tryAgain: String(t("common.try_again")) }} lang={lang} examples={exampleGroups.home} />
                </div>
                <section class="section"><div class="shell card-grid">{infoCards.map((card) => <article class="card"><h3>{card.title}</h3><p>{card.body}</p></article>)}</div></section>
                <section class="section"><div class="shell"><h2>{t("pages:index.index_styles.title")}</h2><p class="muted">{t("pages:index.index_styles.description")}</p><div class="card-grid" style="margin-top:18px;">{styleCards.map((card) => <article class="card"><h3>{card.title}</h3><p>{card.body}</p></article>)}</div></div></section>
                <section class="section"><div class="shell"><h2>{t("pages:index.index_tips.title")}</h2><p class="muted">{t("pages:index.index_tips.description")}</p><div class="card-grid" style="margin-top:18px;">{tipCards.map((card) => <article class="card"><h3>{card.title}</h3><p>{card.body}</p></article>)}</div></div></section>
                <section class="section"><div class="shell faq-card"><h2>{t("pages:index.faq_title")}</h2><div class="list-grid" style="margin-top:18px;">{faqItems("pages:index.faq_items").map((item) => <article class="card"><h3>{item.q}</h3><p>{item.a}</p></article>)}</div></div></section>
            </>
        ) : page.routeKey === "photo-to-chibi" ? (
            <>
                <section class="hero"><div class="shell hero-grid"><div class="hero-copy"><span class="eyebrow">{t("pages:photo-to-chibi.hero_badge")}</span><h1>{t("pages:photo-to-chibi.title")}</h1><p>{t("pages:photo-to-chibi.hero_subtitle")}</p></div><div class="hero-panel"><h2>{t("pages:photo-to-chibi.how_it_works_title")}</h2><div class="list-grid">{photoSteps.map((step) => <article class="card"><h3>{step.title}</h3><p>{step.body}</p></article>)}</div></div></div></section>
                <div class="shell"><GeneratorPanel formId={`photo-generator-${lang}`} labels={{ prompt: String(t("pages:photo-to-chibi.label_notes")), promptPlaceholder: String(t("pages:photo-to-chibi.notes_placeholder")), photo: String(t("pages:photo-to-chibi.label_photo")), photoHelp: String(t("pages:photo-to-chibi.photo_help")), style: String(t("pages:index.label_style")), styleHelp: String(t("pages:photo-to-chibi.style_help")), submit: String(t("pages:photo-to-chibi.generate_btn")), generating: String(t("common.generating")), resultTitle: String(t("pages:photo-to-chibi.result_title")), resultDesc: String(t("pages:index.result_desc")), download: String(t("common.download")), tryAgain: String(t("common.try_again")) }} defaults={{ style: "avatar" }} lang={lang} examples={exampleGroups.photo} /></div>
                <section class="section"><div class="shell"><h2>{t("pages:photo-to-chibi.tips_title")}</h2><div class="card-grid">{photoTips.map((tip) => <article class="card"><h3>{tip.title}</h3><p>{tip.body}</p></article>)}</div></div></section>
                <section class="section"><div class="shell faq-card"><h2>{t("pages:photo-to-chibi.photo_faq_title")}</h2><div class="list-grid">{faqItems("pages:photo-to-chibi.photo_faq_items").map((item) => <article class="card"><h3>{item.q}</h3><p>{item.a}</p></article>)}</div></div></section>
            </>
        ) : page.routeKey === "chibi-avatar-maker" ? (
            <>
                <section class="hero"><div class="shell hero-grid"><div class="hero-copy"><span class="eyebrow">{t("pages:chibi-avatar-maker.hero_badge")}</span><h1>{t("pages:chibi-avatar-maker.title")}</h1><p>{t("pages:chibi-avatar-maker.hero_subtitle")}</p></div><div class="hero-panel"><h2>{t("pages:chibi-avatar-maker.avatar_perfect_for.title")}</h2><div class="list-grid">{avatarPerfectFor.map((item) => <article class="card"><h3>{item.title}</h3><p>{item.body}</p></article>)}</div></div></div></section>
                <div class="shell"><GeneratorPanel formId={`avatar-generator-${lang}`} labels={{ prompt: String(t("pages:chibi-avatar-maker.label_prompt")), promptPlaceholder: String(t("pages:chibi-avatar-maker.prompt_placeholder")), photo: String(t("pages:index.label_photo")), photoHelp: String(t("pages:chibi-avatar-maker.photo_help")), style: String(t("pages:index.label_style")), styleHelp: String(t("pages:chibi-avatar-maker.style_help")), submit: String(t("pages:chibi-avatar-maker.generate_btn")), generating: String(t("pages:chibi-avatar-maker.generating")), resultTitle: String(t("pages:chibi-avatar-maker.result_title")), resultDesc: String(t("pages:chibi-avatar-maker.result_desc")), download: String(t("common.download")), tryAgain: String(t("common.try_again")) }} defaults={{ prompt: String(t("pages:chibi-avatar-maker.prompt_default")), style: "kawaii" }} lang={lang} examples={exampleGroups.avatar} /></div>
                <section class="section"><div class="shell"><h2>{t("pages:chibi-avatar-maker.how_title")}</h2><div class="card-grid">{avatarSteps.map((item) => <article class="card"><h3>{item.title}</h3><p>{item.body}</p></article>)}</div></div></section>
                <section class="section"><div class="shell"><h2>{t("pages:chibi-avatar-maker.avatar_ideas.title")}</h2><p class="muted">{t("pages:chibi-avatar-maker.avatar_ideas.description")}</p><div class="card-grid">{avatarIdeas.map((item) => <article class="card"><h3>{item.title}</h3><p>{item.body}</p></article>)}</div></div></section>
                <section class="section"><div class="shell faq-card"><h2>{t("pages:chibi-avatar-maker.avatar_faq_title")}</h2><div class="list-grid">{faqItems("pages:chibi-avatar-maker.avatar_faq_items").map((item) => <article class="card"><h3>{item.q}</h3><p>{item.a}</p></article>)}</div></div></section>
            </>
        ) : page.routeKey === "chibi-couple-generator" ? (
            <>
                <section class="hero"><div class="shell hero-grid"><div class="hero-copy"><span class="eyebrow">{t("pages:chibi-couple-generator.hero_badge")}</span><h1>{t("pages:chibi-couple-generator.title")}</h1><p>{t("pages:chibi-couple-generator.hero_subtitle")}</p></div><div class="hero-panel"><h2>{t("pages:chibi-couple-generator.how_title")}</h2><div class="list-grid">{coupleSteps.map((item) => <article class="card"><h3>{item.title}</h3><p>{item.body}</p></article>)}</div></div></div></section>
                <div class="shell"><GeneratorPanel formId={`couple-generator-${lang}`} labels={{ prompt: String(t("pages:chibi-couple-generator.label_prompt")), promptPlaceholder: String(t("pages:chibi-couple-generator.prompt_placeholder")), photo: String(t("pages:chibi-couple-generator.label_photo")), photoHelp: String(t("pages:chibi-couple-generator.photo_help")), style: String(t("pages:index.label_style")), styleHelp: String(t("pages:chibi-couple-generator.style_help")), submit: String(t("pages:chibi-couple-generator.generate_btn")), generating: String(t("pages:chibi-couple-generator.generating")), resultTitle: String(t("pages:chibi-couple-generator.result_title")), resultDesc: String(t("pages:chibi-couple-generator.result_desc")), download: String(t("common.download")), tryAgain: String(t("common.try_again")) }} defaults={{ prompt: String(t("pages:chibi-couple-generator.prompt_default")), style: "kawaii" }} lang={lang} examples={exampleGroups.couple} /></div>
                <section class="section"><div class="shell"><h2>{t("pages:chibi-couple-generator.tips_title")}</h2><div class="card-grid">{coupleTips.map((item) => <article class="card"><h3>{item.title}</h3><p>{item.body}</p></article>)}</div></div></section>
                <section class="section"><div class="shell faq-card"><h2>{t("pages:chibi-couple-generator.couple_faq_title")}</h2><div class="list-grid">{faqItems("pages:chibi-couple-generator.couple_faq_items").map((item) => <article class="card"><h3>{item.q}</h3><p>{item.a}</p></article>)}</div></div></section>
            </>
        ) : page.routeKey === "pricing" ? (
            <section class="section"><div class="shell"><div class="hero-copy"><span class="eyebrow">{t("pages:pricing.label")}</span><h1>{t("pages:pricing.title")}</h1><p>{t("pages:pricing.subtitle")}</p></div><div class="pricing-grid" style="margin-top:24px;">{pricingCards.map((card) => <article class="pricing-card"><p class="eyebrow">{card.featured ? t("pages:pricing.popular") : t(`plan.${card.id}`)}</p><h3>{t(`pages:pricing.${card.id}_title`)}</h3><p>{t(`pages:pricing.${card.id}_desc`)}</p><strong class="metric">{card.priceLabel}</strong><p>{card.creditLabel ?? t(`pages:pricing.${card.id}_credit`)}</p>{card.featureKeys && <ul>{card.featureKeys.map((key) => <li>{t(key)}</li>)}</ul>}<div class="action-row" style="margin-top:16px;">{card.paid ? <button class="primary-button" data-checkout-plan={card.id}>{t(card.ctaKey)}</button> : <a class="ghost-button" href={getPathForRoute(lang, "home")}>{t(card.ctaKey)}</a>}</div></article>)}</div><div class="notice" data-payment-message hidden></div></div></section>
        ) : page.routeKey === "features" ? (
            <section class="section"><div class="shell"><div class="hero-copy"><span class="eyebrow">{t("pages:features.label")}</span><h1>{t("pages:features.title")}</h1><p>{t("pages:features.subtitle")}</p></div><div class="card-grid" style="margin-top:24px;">{featureBlocks.map((block) => <article class="card"><h3>{block.title}</h3><p>{block.body}</p></article>)}</div><div class="page-actions" style="margin-top:24px;"><a class="primary-button" href={getPathForRoute(lang, "home")}>{t("pages:features.cta")}</a></div></div></section>
        ) : page.routeKey === "about" ? (
            <section class="section"><div class="shell"><div class="hero-copy"><span class="eyebrow">{t("pages:about.label")}</span><h1>{t("pages:about.title")}</h1><p>{t("pages:about.para1")}</p><p>{t("pages:about.para2")}</p></div><div class="card-grid" style="margin-top:24px;">{aboutValues.map((item) => <article class="card"><h3>{item.title}</h3><p>{item.body}</p></article>)}</div><div class="page-actions" style="margin-top:24px;"><a class="primary-button" href={getPathForRoute(lang, "home")}>{t("pages:about.cta")}</a></div></div></section>
        ) : page.routeKey === "blog" && blogPost ? (
            <section class="section"><div class="shell article-card"><span class="eyebrow">{t("pages:blog.title")}</span><h1>{blogPost.title}</h1><p class="article-intro">{blogPost.excerpt}</p><div class="meta-row"><span>{blogPost.publishedAt}</span><span>{blogPost.readMinutes} {uiText.readMinutesUnit}</span></div><img src={blogPost.cover} alt={blogPost.title} /><div class="list-grid">{blogPost.body.map((paragraph) => <article class="card"><p>{paragraph}</p></article>)}</div><div class="page-actions" style="margin-top:24px;"><a class="ghost-button" href={getPathForRoute(lang, "blog")}>{t("pages:blog.back_to_list")}</a></div></div></section>
        ) : page.routeKey === "blog" ? (
            <section class="section"><div class="shell"><div class="hero-copy"><span class="eyebrow">{t("pages:blog.title")}</span><h1>{t("pages:blog.title")}</h1><p>{t("pages:blog.subtitle")}</p></div><div class="blog-grid" style="margin-top:24px;">{posts.map((post) => <article class="blog-card"><img src={post.cover} alt={post.title} /><div class="meta-row"><span>{post.publishedAt}</span><span>{post.readMinutes} {uiText.readMinutesUnit}</span></div><h3>{post.title}</h3><p>{post.excerpt}</p><a class="ghost-button" href={getPathForRoute(lang, "blog", [post.slug])}>{t("pages:blog.back_to_list")}</a></article>)}</div></div></section>
        ) : page.routeKey === "dashboard" ? (
            <section class="section"><div class="shell"><div class="hero-copy"><span class="eyebrow">{t("pages:dashboard.label")}</span><h1>{t("pages:dashboard.title")}</h1><p>{t("pages:dashboard.subtitle")}</p></div><div class="dashboard-grid" style="margin-top:24px;"><article class="dashboard-card"><h3>{t("pages:dashboard.current_plan")}</h3><strong class="metric" data-plan-value>{t("common.loading")}</strong><p data-status-value>{t("common.loading")}</p></article><article class="dashboard-card"><h3>{t("pages:dashboard.monthly_usage")}</h3><strong class="metric" data-credit-value>0</strong><p data-expiry-value>{t("common.loading")}</p></article><article class="dashboard-card"><h3>{t("nav.login")}</h3><div class="action-row"><button class="primary-button" data-checkout-plan="starter">{t("pages:dashboard.upgrade")}</button><button class="ghost-button" data-open-portal>{t("pages:dashboard.manage")}</button></div></article></div><div class="dashboard-card" style="margin-top:24px;"><div class="toolbar"><h2 style="margin-bottom:0;">{t("pages:dashboard.recent_title")}</h2><button class="ghost-button" data-dashboard-refresh>{t("pages:dashboard.refresh")}</button></div><p class="muted">{t("pages:dashboard.recent_desc")}</p><div class="examples-grid" data-history-grid></div><div class="empty-card" data-login-callout style="margin-top:18px;" hidden><h3>{t("pages:dashboard.login_title")}</h3><p>{t("pages:dashboard.login_desc")}</p><a class="primary-button" href="/api/auth/google">{t("nav.login")}</a></div></div></div></section>
            <script is:inline>
                (() => {
                    const historyGrid = document.querySelector("[data-history-grid]");
                    const planValue = document.querySelector("[data-plan-value]");
                    const statusValue = document.querySelector("[data-status-value]");
                    const creditValue = document.querySelector("[data-credit-value]");
                    const expiryValue = document.querySelector("[data-expiry-value]");
                    const loginCallout = document.querySelector("[data-login-callout]");
                    const refreshButton = document.querySelector("[data-dashboard-refresh]");
                    const renderHistory = (items) => {
                        if (!historyGrid) return;
                        historyGrid.innerHTML = "";
                        if (!items.length) {
                            historyGrid.innerHTML = `<article class=\"empty-card\"><p>${JSON.stringify(String(t("pages:dashboard.empty"))).slice(1, -1)}</p></article>`;
                            return;
                        }
                        for (const item of items) {
                            const card = document.createElement("article");
                            card.className = "example-card";
                            card.innerHTML = `<img src="${item.output_url}" alt="${item.prompt || uiText.fallbackPrompt}" loading="lazy" /><figcaption>${item.prompt || item.style || uiText.fallbackName}</figcaption>`;
                            historyGrid.appendChild(card);
                        }
                    };
                    const load = async () => {
                        try {
                            const authResponse = await fetch("/api/auth/me", { credentials: "include" });
                            if (authResponse.status === 401) {
                                loginCallout?.removeAttribute("hidden");
                                renderHistory([]);
                                if (planValue) planValue.textContent = uiText.anonymousPlan;
                                if (statusValue) statusValue.textContent = uiText.dashboardAnonymous;
                                if (creditValue) creditValue.textContent = "0";
                                if (expiryValue) expiryValue.textContent = uiText.dashboardNoSession;
                                return;
                            }
                            const auth = await authResponse.json();
                            loginCallout?.setAttribute("hidden", "hidden");
                            if (planValue) planValue.textContent = auth.subscription?.plan ? (uiText[`plan${auth.subscription.plan.charAt(0).toUpperCase()}${auth.subscription.plan.slice(1)}`] || auth.subscription.plan) : uiText.defaultPlan;
                            if (statusValue) statusValue.textContent = auth.subscription?.status ? (uiText[`status${auth.subscription.status.charAt(0).toUpperCase()}${auth.subscription.status.slice(1)}`] || auth.subscription.status) : uiText.defaultStatus;
                            if (creditValue) creditValue.textContent = String(auth.credits?.available ?? 0);
                            if (expiryValue) expiryValue.textContent = auth.credits?.expiring_at || uiText.dashboardNoExpiry;
                            const history = await fetch("/api/images/history", { credentials: "include" }).then((res) => res.json());
                            renderHistory(history.items || []);
                        } catch {
                            if (historyGrid) historyGrid.innerHTML = `<article class=\"empty-card\"><p>${JSON.stringify(uiText.dashboardHistoryError).slice(1, -1)}</p></article>`;
                        }
                    };
                    refreshButton?.addEventListener("click", load);
                    window.addEventListener("chibi-generated", load);
                    load();
                })();
            </script>
        ) : page.routeKey === "admin" ? (
            <section class="section"><div class="shell"><div class="hero-copy"><span class="eyebrow">{t("pages:admin.label")}</span><h1>{t("pages:admin.title")}</h1><p>{t("pages:admin.subtitle")}</p></div><div class="admin-panel" style="margin-top:24px;"><div class="toolbar"><button class="ghost-button" data-admin-refresh>{t("pages:admin.refresh")}</button><span class="muted" data-admin-status>{t("pages:admin.loading")}</span></div><div class="table-wrap" style="margin-top:18px;"><table><thead><tr><th>{t("pages:admin.col_user")}</th><th>{t("pages:admin.col_plan")}</th><th>{t("pages:admin.col_usage")}</th><th>{t("pages:admin.col_registered")}</th><th>{t("pages:admin.col_actions")}</th></tr></thead><tbody data-admin-body></tbody></table></div></div></div></section>
            <script is:inline>
                (() => {
                    const body = document.querySelector("[data-admin-body]");
                    const status = document.querySelector("[data-admin-status]");
                    const refresh = document.querySelector("[data-admin-refresh]");
                    const render = (items) => {
                        if (!body) return;
                        body.innerHTML = "";
                        if (!items.length) {
                            body.innerHTML = `<tr><td colspan=\"5\">${JSON.stringify(String(t("pages:admin.no_users"))).slice(1, -1)}</td></tr>`;
                            return;
                        }
                        for (const item of items) {
                            const tr = document.createElement("tr");
                            tr.innerHTML = `<td>${item.name || item.email || uiText.adminUnnamed}</td><td><select data-plan-select><option value=\"free\" ${item.plan === "free" ? "selected" : ""}>${uiText.adminPlanFree}</option><option value=\"starter\" ${item.plan === "starter" ? "selected" : ""}>${uiText.adminPlanStarter}</option><option value=\"standard\" ${item.plan === "standard" ? "selected" : ""}>${uiText.adminPlanStandard}</option><option value=\"value\" ${item.plan === "value" ? "selected" : ""}>${uiText.adminPlanValue}</option></select></td><td>${item.credits} ${uiText.adminCreditsLabel} / ${item.total_images} ${uiText.adminImageUnit}</td><td>${item.created_at}</td><td><div class=\"action-row\"><input type=\"number\" value=\"10\" step=\"1\" style=\"max-width:100px;\" /><button class=\"ghost-button\" data-fill>${JSON.stringify(String(t("pages:admin.credits_btn"))).slice(1, -1)}</button><button class=\"primary-button\" data-set-plan>${JSON.stringify(String(t("pages:admin.plan_btn"))).slice(1, -1)}</button></div></td>`;
                            const amountInput = tr.querySelector("input");
                            const planSelect = tr.querySelector("select");
                            tr.querySelector("[data-fill]")?.addEventListener("click", async () => {
                                await fetch("/api/admin/fill-credits", { method: "POST", headers: { "Content-Type": "application/json" }, body: JSON.stringify({ userId: item.id, amount: Number(amountInput?.value || 0) }) });
                                load();
                            });
                            tr.querySelector("[data-set-plan]")?.addEventListener("click", async () => {
                                await fetch("/api/admin/set-plan", { method: "POST", headers: { "Content-Type": "application/json" }, body: JSON.stringify({ userId: item.id, plan: planSelect?.value || "free" }) });
                                load();
                            });
                            body.appendChild(tr);
                        }
                    };
                    const load = async () => {
                        if (status) status.textContent = ${JSON.stringify(String(t("pages:admin.refreshing"))).slice(1, -1)};
                        const response = await fetch("/api/admin/users", { credentials: "include" });
                        if (!response.ok) {
                            if (status) status.textContent = response.status === 403 ? uiText.adminAccessRequired : ${JSON.stringify(String(t("pages:admin.load_failed"))).slice(1, -1)};
                            render([]);
                            return;
                        }
                        const payload = await response.json();
                        render(payload.items || []);
                        if (status) status.textContent = `${payload.items?.length || 0} ${uiText.adminStatusUsers}`;
                    };
                    refresh?.addEventListener("click", load);
                    load();
                })();
            </script>
        ) : null
    }

    <script is:inline>
        (() => {
            const message = document.querySelector("[data-payment-message]");
            const setMessage = (value) => {
                if (!message) return;
                message.hidden = !value;
                message.textContent = value || "";
            };
            document.querySelectorAll("[data-checkout-plan]").forEach((button) => {
                button.addEventListener("click", async () => {
                    const plan = button.getAttribute("data-checkout-plan");
                    if (!plan) return;
                    setMessage(uiText.paymentLoadingCheckout);
                    const response = await fetch("/api/payments/create-checkout", { method: "POST", headers: { "Content-Type": "application/json" }, body: JSON.stringify({ plan }) });
                    const payload = await response.json();
                    if (!response.ok) {
                        setMessage(payload.error || uiText.paymentCheckoutFailed);
                        return;
                    }
                    window.location.href = payload.url;
                });
            });
            document.querySelectorAll("[data-open-portal]").forEach((button) => {
                button.addEventListener("click", async () => {
                    const response = await fetch("/api/payments/create-portal", { method: "POST" });
                    const payload = await response.json();
                    if (!response.ok) {
                        alert(payload.error || uiText.paymentPortalFailed);
                        return;
                    }
                    window.location.href = payload.url;
                });
            });
        })();
    </script>
</Base>
