---
import Footer from "@/components/Footer.astro";
import Header from "@/components/Header.astro";
import { getLangFromUrl } from "@/i18n/utils";
import "@/styles/global.css";

interface Props {
    title: string;
    meta?: {
        description?: string;
        image?: string;
        type?: string;
        url?: string;
        keywords?: string;
        canonical?: string;
        robots?: string;
    };
}

const { title, meta = {} } = Astro.props as Props;
const lang = getLangFromUrl(Astro.url);
const pageTitle = `${title} | AI Chibi Generator`;
const canonical = meta.canonical ?? Astro.url.href;
const description = meta.description ?? "AI Chibi Generator";
const image = meta.image ?? "/og-image.jpg";
const initialThemeColor = "#f8fafc";
---

<html lang={lang} data-theme="starter">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <meta name="theme-color" content={initialThemeColor} />
        <script is:inline>
            (() => {
                const syncThemeColor = () => {
                    const meta = document.querySelector('meta[name="theme-color"]');
                    const color = getComputedStyle(document.documentElement).getPropertyValue("--theme-color").trim();
                    if (meta && color) {
                        meta.setAttribute("content", color);
                    }
                };
                syncThemeColor();
                new MutationObserver(syncThemeColor).observe(document.documentElement, {
                    attributes: true,
                    attributeFilter: ["class", "data-theme"],
                });
            })();
        </script>
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&family=Space+Grotesk:wght@500;700&display=swap" rel="stylesheet" />
        <link rel="icon" type="image/png" href="/chibi-assets/favicon-32x32.png" />
        <link rel="shortcut icon" href="/chibi-assets/favicon.ico" />
        <title>{pageTitle}</title>
        <meta name="description" content={description} />
        {meta.keywords && <meta name="keywords" content={meta.keywords} />}
        <meta name="robots" content={meta.robots ?? "index,follow"} />
        <link rel="canonical" href={canonical} />
        <meta property="og:title" content={pageTitle} />
        <meta property="og:description" content={description} />
        <meta property="og:type" content={meta.type ?? "website"} />
        <meta property="og:image" content={image} />
        <meta property="og:url" content={meta.url ?? Astro.url.href} />
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content={pageTitle} />
        <meta name="twitter:description" content={description} />
        <meta name="twitter:image" content={image} />
    </head>
    <body>
        <Header />
        <main>
            <slot />
        </main>
        <Footer />
    </body>
</html>
