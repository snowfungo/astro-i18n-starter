APP_ENV=development
APP_URL=http://localhost:4321
PRODUCTION_DOMAIN=https://your-domain.com
SECRET_KEY=change-me-in-production
DATABASE_PATH=./runtime/chibi-app.db

STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4321/api/auth/callback/google

AI_CONTENT_SERVICE_URL=http://127.0.0.1:8020
AI_CONTENT_SERVICE_TOKEN=
AI_CHIBI_GENERATION_PROVIDER=mock
AI_CHIBI_IMAGE_MODEL=gpt-image-2
AI_CHIBI_IMAGE_SIZE=1:1
AI_CHIBI_GENERATION_TIMEOUT=900
AI_CHIBI_ALLOW_MOCK_FALLBACK=true

ANON_IMAGE_DAILY_LIMIT=3
ANON_IMAGE_QUOTA_ENABLED=true
ANON_IMAGE_LIMIT_REFUND_ON_PROVIDER_ERROR=false
MAX_REQUEST_BODY_SIZE=8388608
TRUSTED_PROXY_IPS=127.0.0.1,::1
CLIENT_IP_HEADER_ORDER=CF-Connecting-IP,X-Real-IP,X-Forwarded-For
COOKIE_ACCESS_TOKEN=access_token
COOKIE_REFRESH_TOKEN=refresh_token
COOKIE_SESSION_ID=chibi_session_id

DEV_API_TEST_KEY=local-smoke-test-key
MOCK_USER_EMAIL=dev-test@example.com
ADMIN_USERS=dev-test@example.com
TEST_USERS=dev-test@example.com

DEV_AUTH_MOCK=false
DEV_STRIPE_MOCK=false
DEV_USER_EMAIL=dev-test@example.com
